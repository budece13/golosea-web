---
import { content, palette, fonts, business } from "../data/golosea";
import Navbar from "../components/Navbar.astro";
import ChatBot from "../components/ChatBot.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = content.seo_title,
  description = content.seo_description,
} = Astro.props;

const headingFamily = encodeURIComponent(fonts.heading);
const bodyFamily    = encodeURIComponent(fonts.body);
const googleFontsUrl =
  `https://fonts.googleapis.com/css2?family=${headingFamily}:wght@600;700;800&family=${bodyFamily}:wght@400;500;600;700&display=swap`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={googleFontsUrl} />
  </head>

  <body>
    <Navbar />
    <slot />

    <!-- WhatsApp flotante -->
    <a
      class="wa-float"
      href={`https://wa.me/${business.whatsapp}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
    >
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <path d="M16 3C9 3 3.5 8.5 3.5 15.5c0 2.3.6 4.4 1.7 6.3L3 29l7.4-2.1c1.8 1 3.9 1.5 6 1.5 7 0 12.5-5.5 12.5-12.5S23 3 16 3zm0 22.7c-1.9 0-3.7-.5-5.3-1.4l-.4-.2-4.4 1.2 1.2-4.3-.3-.4c-1-1.6-1.5-3.5-1.5-5.4C5.5 9.6 10.2 5 16 5s10.5 4.6 10.5 10.5S21.8 25.7 16 25.7zm5.8-7.8c-.3-.2-1.9-.9-2.1-1s-.5-.2-.7.2-.8 1-1 1.2-.4.2-.7.1c-1.9-.9-3.1-1.7-4.3-3.8-.3-.6.3-.5.9-1.7.1-.2 0-.4 0-.5l-1-2.4c-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-1 1-1.3 2.3-1.3 3.9 0 2.3 1.7 4.5 1.9 4.8.2.3 3.3 5 8 7 .7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.9-.8 2.1-1.5.3-.8.3-1.4.2-1.5-.1-.2-.3-.3-.6-.4z"/>
      </svg>
    </a>

    <ChatBot />
  </body>
</html>

<style define:vars={{
  colorPrimary: palette.primary,
  colorAccent:  palette.accent,
  colorDark:    palette.dark,
  colorLight:   palette.light,
  fontHeading:  `"${fonts.heading}", system-ui, sans-serif`,
  fontBody:     `"${fonts.body}", system-ui, sans-serif`,
}}>
  :root {
    --color-primary: var(--colorPrimary);
    --color-accent:  var(--colorAccent);
    --color-dark:    var(--colorDark);
    --color-light:   var(--colorLight);
    --font-heading:  var(--fontHeading);
    --font-body:     var(--fontBody);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    background-color: #fff;
    color: var(--color-dark);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    line-height: 1.2;
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .wa-float {
    position: fixed;
    bottom: 22px;
    left: 22px;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: #25D366;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.25);
    z-index: 60;
    transition: transform 0.15s;
  }

  .wa-float:hover {
    transform: scale(1.08);
  }

  .wa-float svg {
    width: 32px;
    height: 32px;
    fill: #fff;
  }
</style>
