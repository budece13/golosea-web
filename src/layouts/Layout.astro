---
import { content, palette, fonts } from "../data/golosea";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ChatBot from "../components/ChatBot.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = content.seo_title,
  description = content.seo_description,
} = Astro.props;

const headingFamily = encodeURIComponent(fonts.heading);
const bodyFamily    = encodeURIComponent(fonts.body);
const googleFontsUrl =
  `https://fonts.googleapis.com/css2?family=${headingFamily}:wght@600;700;800&family=${bodyFamily}:wght@400;500;600;700&display=swap`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={googleFontsUrl} />
    <!-- Fuentes del hero: Anton (eyebrow) + Titan One (titular, provisional) -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Anton&family=Titan+One&display=swap"
    />
  </head>

  <body>
    <Navbar />
    <slot />
    <Footer />

    <ChatBot />
  </body>
</html>

<style define:vars={{
  colorPrimary: palette.primary,
  colorAccent:  palette.accent,
  colorDark:    palette.dark,
  colorLight:   palette.light,
  fontHeading:  `"${fonts.heading}", system-ui, sans-serif`,
  fontBody:     `"${fonts.body}", system-ui, sans-serif`,
}}>
  :root {
    --color-primary: var(--colorPrimary);
    --color-accent:  var(--colorAccent);
    --color-dark:    var(--colorDark);
    --color-light:   var(--colorLight);
    --font-heading:  var(--fontHeading);
    --font-body:     var(--fontBody);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    background-color: #fff;
    color: var(--color-dark);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    line-height: 1.2;
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

</style>

<!-- Estilos compartidos por todas las páginas (botones, contenedores, títulos de sección) -->
<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  a {
    color: inherit;
    text-decoration: none;
  }
  img {
    max-width: 100%;
    display: block;
  }
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    line-height: 1.2;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .section {
    padding: 72px 0;
  }

  .section-title {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-title h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: var(--color-dark);
  }

  .section-title span {
    color: var(--color-primary);
  }

  .btn {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 14px 28px;
    border-radius: 999px;
    font-weight: 700;
    font-family: var(--font-body);
    font-size: 1rem;
    border: none;
    cursor: pointer;
    transition: transform 0.15s, filter 0.15s;
    text-decoration: none;
  }

  .btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.05);
  }

  .btn-outline {
    background: transparent;
    border: 2px solid #fff;
    color: #fff;
  }

  /* Estados de interacción accesibles (no alteran el reposo) */
  .btn:active {
    transform: translateY(0);
    filter: brightness(0.98);
  }
  .btn:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }

  a:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* La navbar sticky (68px) no debe tapar las secciones ancladas */
  section[id] {
    scroll-margin-top: 84px;
  }
</style>
