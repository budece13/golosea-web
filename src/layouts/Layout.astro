---
import { content, palette, fonts } from "../data/golosea";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ChatBot from "../components/ChatBot.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = content.seo_title,
  description = content.seo_description,
} = Astro.props;

// Ranchers solo tiene peso 400; Fredoka y Nunito si son variables.
const headingFamily    = encodeURIComponent(fonts.heading);
const subheadingFamily = encodeURIComponent(fonts.subheading);
const bodyFamily       = encodeURIComponent(fonts.body);
const googleFontsUrl =
  `https://fonts.googleapis.com/css2?family=${headingFamily}` +
  `&family=${subheadingFamily}:wght@500;600;700` +
  `&family=${bodyFamily}:wght@400;500;600;700&display=swap`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" href="/favicon/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={googleFontsUrl} />
    <!-- Fuentes propias del hero (Anton + Titan One) — para no alterar su aspecto -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Anton&family=Titan+One&display=swap"
    />
  </head>

  <body>
    <Navbar />
    <slot />
    <Footer />

    <ChatBot />
  </body>
</html>

<style define:vars={{
  colorPrimary:     palette.primary,
  colorPrimaryDark: palette.primaryDark,
  colorAccent:      palette.accent,
  colorAccentDark:  palette.accentDark,
  colorDark:        palette.dark,
  colorLight:       palette.light,
  fontHeading:    `"${fonts.heading}", system-ui, sans-serif`,
  fontSubheading: `"${fonts.subheading}", system-ui, sans-serif`,
  fontBody:       `"${fonts.body}", system-ui, sans-serif`,
}}>
  :root {
    --color-primary:      var(--colorPrimary);
    --color-primary-dark: var(--colorPrimaryDark);
    --color-accent:       var(--colorAccent);
    --color-accent-dark:  var(--colorAccentDark);
    --color-dark:         var(--colorDark);
    --color-light:        var(--colorLight);
    --font-heading:    var(--fontHeading);
    --font-subheading: var(--fontSubheading);
    --font-body:       var(--fontBody);
  }

  html {
    scroll-behavior: smooth;
    /* iOS Safari: evita que rote/aumente el texto al girar el móvil */
    -webkit-text-size-adjust: 100%;
    text-size-adjust: 100%;
  }

  body {
    font-family: var(--font-body);
    background-color: #fff;
    color: var(--color-dark);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    /* iOS Safari: cualquier desborde puntual no debe crear scroll horizontal */
    overflow-x: hidden;
    /* quita el flash gris al tocar enlaces/botones en iOS */
    -webkit-tap-highlight-color: transparent;
  }
</style>

<!-- Estilos compartidos por todas las páginas -->
<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  a {
    color: inherit;
    text-decoration: none;
  }
  img {
    max-width: 100%;
    display: block;
  }
  h1 {
    font-family: var(--font-heading);
    line-height: 1.1;
  }
  h2, h3, h4, h5, h6 {
    font-family: var(--font-subheading);
    line-height: 1.2;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .section {
    padding: 72px 0;
  }

  .section-title {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-title h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: var(--color-dark);
  }

  .section-title span {
    color: var(--color-primary);
  }

  /* ── Botones estilo gominola brillante ── */
  .btn {
    --btn-bg: var(--color-accent);
    --btn-bg-dark: var(--color-accent-dark);
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4em;
    padding: 15px 32px;
    border: none;
    border-radius: 999px;
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 1rem;
    line-height: 1;
    color: #fff;
    text-decoration: none;
    cursor: pointer;
    overflow: hidden;
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.12);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--btn-bg) 78%, #fff) 0%,
      var(--btn-bg) 50%,
      var(--btn-bg-dark) 100%
    );
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.4),
      inset 0 -2px 5px rgba(0, 0, 0, 0.1),
      0 5px 11px -5px color-mix(in srgb, var(--btn-bg) 60%, #000);
    transition: transform 0.16s ease, box-shadow 0.16s ease, filter 0.16s ease;
  }
  /* reflejo superior tipo gel (sutil) */
  .btn::before {
    content: "";
    position: absolute;
    top: 4px;
    left: 14%;
    right: 14%;
    height: 34%;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.32), rgba(255, 255, 255, 0));
    pointer-events: none;
  }
  .btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.02);
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.45),
      inset 0 -2px 5px rgba(0, 0, 0, 0.1),
      0 8px 15px -5px color-mix(in srgb, var(--btn-bg) 55%, #000);
  }
  .btn:active {
    transform: translateY(1px);
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.18),
      inset 0 -1px 3px rgba(255, 255, 255, 0.25),
      0 3px 8px -5px color-mix(in srgb, var(--btn-bg) 60%, #000);
  }
  .btn:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--btn-bg) 60%, #fff);
    outline-offset: 3px;
  }

  /* Variantes de color */
  /* Verde: ghost con acento suave en reposo, relleno gominola al hover/activo */
  .btn--accent {
    --btn-bg: var(--color-accent);
    --btn-bg-dark: var(--color-accent-dark);
    color: var(--color-accent);
    text-shadow: none;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    box-shadow: inset 0 0 0 2px color-mix(in srgb, var(--color-accent) 85%, transparent);
  }
  .btn--accent::before { opacity: 0; transition: opacity 0.16s ease; }
  .btn--accent:hover,
  .btn--accent:active {
    color: #fff;
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.12);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--btn-bg) 78%, #fff) 0%,
      var(--btn-bg) 50%,
      var(--btn-bg-dark) 100%
    );
  }
  .btn--accent:hover::before,
  .btn--accent:active::before { opacity: 1; }
  .btn--primary {
    --btn-bg: var(--color-primary);
    --btn-bg-dark: var(--color-primary-dark);
  }
  .btn--whatsapp {
    --btn-bg: #25d366;
    --btn-bg-dark: #1da851;
  }

  /* Variante compacta (navbar, controles pequeños) */
  .btn--sm {
    padding: 11px 22px;
    font-size: 0.9rem;
  }

  /* Icono dentro del botón */
  .btn svg {
    width: 1.2em;
    height: 1.2em;
    flex-shrink: 0;
  }

  /* Variante translúcida tipo gominola transparente (sobre fondos con imagen) */
  .btn--outline {
    background: rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    box-shadow:
      inset 0 0 0 2px rgba(255, 255, 255, 0.85),
      inset 0 2px 3px rgba(255, 255, 255, 0.45),
      0 8px 16px -6px rgba(0, 0, 0, 0.45);
  }
  .btn--outline::before {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0));
  }
  .btn--outline:hover {
    background: rgba(255, 255, 255, 0.24);
    filter: none;
  }

  a:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* La navbar sticky no debe tapar las secciones ancladas */
  section[id] {
    scroll-margin-top: 84px;
  }
</style>
