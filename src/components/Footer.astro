---
import { business, content } from "../data/golosea";

const wa = `https://wa.me/${business.whatsapp}`;
const tel = `tel:${business.phone.replace(/\s/g, "")}`;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a href="/" class="f-brand">
        <img src="/logo/golosea-logo.png" alt={business.name} class="f-brand-logo" width="190" height="56" />
      </a>
      <p class="f-tagline">{content.tagline}</p>
      <a class="btn btn--whatsapp f-wa" href={wa} target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.044zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z" />
        </svg>
        Escríbenos por WhatsApp
      </a>
    </div>

    <nav class="f-col" aria-label="Enlaces del sitio">
      <h4>Explora</h4>
      <a href="/#encargos">Encargos</a>
      <a href="/#galeria">Galería</a>
      <a href="/#resenas">Reseñas</a>
      <a href="/sobre-golosea">Sobre Golosea</a>
      <a href="/festivos">Festivos y novedades</a>
    </nav>

    <div class="f-col">
      <h4>Visítanos</h4>
      <p class="f-item">
        <svg class="f-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" />
        </svg>
        <span>{business.address}</span>
      </p>
      <a class="f-item" href={tel}>
        <svg class="f-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z" />
        </svg>
        <span>{business.phone}</span>
      </a>
    </div>
  </div>

  <div class="container f-bottom">
    <small>© {year} {business.name} · El Bonillo, Albacete</small>
    <small>Creada por Propus</small>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background-image: url('/footer/fondo-footer.webp');
    background-position: 80% center;
    background-size: cover;
    padding: 56px 0 0;
  }

  /* Overlay oscuro DETRÁS del contenido para dar contraste al texto */
  .site-footer::after {
    content: "";
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.35);
    z-index: 0;
  }

  /* El contenido por encima del overlay */
  .footer-grid,
  .f-bottom {
    position: relative;
    z-index: 1;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.2fr;
    gap: 48px;
    padding-bottom: 44px;
  }

  .f-brand {
    display: inline-flex;
    align-items: center;
    margin-bottom: 12px;
  }
  .f-brand-logo {
    height: 52px;
    width: auto;
  }

  .f-tagline {
    color: rgba(255, 255, 255, 0.82);
    max-width: 300px;
    line-height: 1.55;
    margin-bottom: 22px;
  }


  .f-col h4 {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.95rem;
    color: #fff;
    margin-bottom: 16px;
  }
  .f-col > a,
  .f-col > p {
    display: block;
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.96rem;
    line-height: 1.5;
    margin-bottom: 12px;
    transition: color 0.15s ease;
  }
  .f-col > a:hover { color: #fff; }

  .f-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .f-ico {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-accent);
  }

  .f-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    padding-top: 20px;
    padding-bottom: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
  }
  .f-bottom small { color: rgba(255, 255, 255, 0.62); font-size: 0.82rem; }

  .f-brand:focus-visible,
  .f-wa:focus-visible,
  .f-col a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 6px;
  }

  @media (prefers-reduced-motion: reduce) {
    .f-wa, .f-col > a { transition: none; }
  }

  @media (max-width: 760px) {
    .footer-grid { grid-template-columns: 1fr; gap: 34px; }
    .f-bottom { flex-direction: column; text-align: center; }
  }
</style>
