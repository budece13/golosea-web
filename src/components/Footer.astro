---
import { business, content } from "../data/golosea";

const wa = `https://wa.me/${business.whatsapp}`;
const tel = `tel:${business.phone.replace(/\s/g, "")}`;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a href="/" class="f-brand">
        <svg class="f-brand-mark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m9.5 7.5-2 2a4.95 4.95 0 1 0 7 7l2-2a4.95 4.95 0 1 0-7-7Z" />
          <path d="M14 6.5v10" /><path d="M10 7.5v10" />
          <path d="m16 7 1-5 1.37.68A3 3 0 0 0 19.7 3H21v1.3c0 .46.1.92.32 1.33L22 7l-5 1" />
          <path d="m8 17-1 5-1.37-.68A3 3 0 0 0 4.3 21H3v-1.3a3 3 0 0 0-.32-1.33L2 17l5-1" />
        </svg>
        <span>{business.name}</span>
      </a>
      <p class="f-tagline">{content.tagline}</p>
      <a class="f-wa" href={wa} target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
          <path d="M16 3C9 3 3.5 8.5 3.5 15.5c0 2.3.6 4.4 1.7 6.3L3 29l7.4-2.1c1.8 1 3.9 1.5 6 1.5 7 0 12.5-5.5 12.5-12.5S23 3 16 3zm0 22.7c-1.9 0-3.7-.5-5.3-1.4l-.4-.2-4.4 1.2 1.2-4.3-.3-.4c-1-1.6-1.5-3.5-1.5-5.4C5.5 9.6 10.2 5 16 5s10.5 4.6 10.5 10.5S21.8 25.7 16 25.7zm5.8-7.8c-.3-.2-1.9-.9-2.1-1s-.5-.2-.7.2-.8 1-1 1.2-.4.2-.7.1c-1.9-.9-3.1-1.7-4.3-3.8-.3-.6.3-.5.9-1.7.1-.2 0-.4 0-.5l-1-2.4c-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-1 1-1.3 2.3-1.3 3.9 0 2.3 1.7 4.5 1.9 4.8.2.3 3.3 5 8 7 .7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.9-.8 2.1-1.5.3-.8.3-1.4.2-1.5-.1-.2-.3-.3-.6-.4z" />
        </svg>
        Escríbenos por WhatsApp
      </a>
    </div>

    <nav class="f-col" aria-label="Enlaces del sitio">
      <h4>Explora</h4>
      <a href="/#encargos">Encargos</a>
      <a href="/#galeria">Galería</a>
      <a href="/#resenas">Reseñas</a>
      <a href="/sobre-golosea">Sobre Golosea</a>
      <a href="/festivos">Festivos y novedades</a>
    </nav>

    <div class="f-col">
      <h4>Visítanos</h4>
      <p class="f-item">
        <svg class="f-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" />
        </svg>
        <span>{business.address}</span>
      </p>
      <a class="f-item" href={tel}>
        <svg class="f-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z" />
        </svg>
        <span>{business.phone}</span>
      </a>
      <p class="f-item f-rating">
        <svg class="f-ico" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z" />
        </svg>
        <span>{business.rating}/5 · {business.ratingsCount} reseñas</span>
      </p>
    </div>
  </div>

  <div class="container f-bottom">
    <small>© {year} {business.name} · El Bonillo, Albacete</small>
    <small>Web creada con IA</small>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-dark);
    color: #fff;
    padding: 56px 0 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.2fr;
    gap: 48px;
    padding-bottom: 44px;
  }

  .f-brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 12px;
  }
  .f-brand-mark { width: 27px; height: 27px; color: var(--color-accent); }

  .f-tagline {
    color: rgba(255, 255, 255, 0.82);
    max-width: 300px;
    line-height: 1.55;
    margin-bottom: 22px;
  }

  .f-wa {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    padding: 11px 18px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.92rem;
    transition: background 0.18s ease, transform 0.18s ease;
  }
  .f-wa svg { width: 18px; height: 18px; color: #25d366; }
  .f-wa:hover { background: rgba(255, 255, 255, 0.2); transform: translateY(-1px); }

  .f-col h4 {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.95rem;
    color: #fff;
    margin-bottom: 16px;
  }
  .f-col > a,
  .f-col > p {
    display: block;
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.96rem;
    line-height: 1.5;
    margin-bottom: 12px;
    transition: color 0.15s ease;
  }
  .f-col > a:hover { color: #fff; }

  .f-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .f-ico {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-accent);
  }
  .f-rating { color: #fff; }

  .f-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    padding-top: 20px;
    padding-bottom: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
  }
  .f-bottom small { color: rgba(255, 255, 255, 0.62); font-size: 0.82rem; }

  .f-brand:focus-visible,
  .f-wa:focus-visible,
  .f-col a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 6px;
  }

  @media (prefers-reduced-motion: reduce) {
    .f-wa, .f-col > a { transition: none; }
  }

  @media (max-width: 760px) {
    .footer-grid { grid-template-columns: 1fr; gap: 34px; }
    .f-bottom { flex-direction: column; text-align: center; }
  }
</style>
