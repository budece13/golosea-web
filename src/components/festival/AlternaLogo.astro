---
// Recreación del logotipo "ALTERNA FESTIVAL" para el hero.
// Tipografía alta (Anton), Я invertida, alternando rojo/blanco + insignia del rayo.
interface Props {
  class?: string;
}
const { class: cls = "" } = Astro.props;

// A L T E Я N A — rojo en la A inicial y la Я; resto en blanco.
const letters = [
  { ch: "A", color: "red" },
  { ch: "L", color: "white" },
  { ch: "T", color: "white" },
  { ch: "E", color: "white" },
  { ch: "R", color: "red", flip: true },
  { ch: "N", color: "white" },
  { ch: "A", color: "white" },
];
const bolt = "M40 2 L14 34 L30 34 L24 62 L52 26 L34 26 Z";
---

<div class:list={["alogo", cls]} role="img" aria-label="Alterna Festival">
  <span class="alogo__badge" aria-hidden="true">
    <svg viewBox="0 0 64 64"><path d={bolt} fill="#fff" /></svg>
  </span>

  <div class="alogo__word" aria-hidden="true">
    {letters.map((l) => (
      <span class:list={["al", l.color, { flip: l.flip }]}>{l.ch}</span>
    ))}
  </div>

  <div class="alogo__festival" aria-hidden="true">
    <span class="alogo__spark"><svg viewBox="0 0 64 64"><path d={bolt} fill="#fff" /></svg></span>
    <span class="alogo__festtext">FESTIVAL</span>
    <span class="alogo__spark"><svg viewBox="0 0 64 64"><path d={bolt} fill="#fff" /></svg></span>
  </div>
</div>

<style>
  .alogo {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    --red: #ef4d62;
    --red-deep: #b8203a;
    --ink: #1f1a17;
  }

  /* ── Insignia del rayo ─────────────────────────────────────────── */
  .alogo__badge {
    width: clamp(64px, 9vw, 92px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--red);
    display: grid;
    place-items: center;
    margin: 0 0 -6px 4px;
    box-shadow:
      inset 0 0 0 5px var(--red),
      inset 0 0 0 9px #fff,
      inset 0 0 0 13px var(--red),
      0 6px 0 var(--red-deep),
      0 12px 22px rgba(31, 26, 23, 0.3);
    border: 3px solid #ffd4da;
  }
  .alogo__badge svg { width: 42%; height: 42%; filter: drop-shadow(0 2px 0 var(--red-deep)); }

  /* ── Palabra ALTERNA ───────────────────────────────────────────── */
  .alogo__word {
    display: flex;
    align-items: flex-end;
    transform: scaleY(1.1);
    transform-origin: bottom left;
  }
  .al {
    font-family: "Anton", var(--font-heading), sans-serif;
    font-weight: 400;
    font-size: clamp(3rem, 9.5vw, 6.4rem);
    line-height: 0.86;
    letter-spacing: -0.02em;
    display: inline-block;
  }
  .al.red {
    color: var(--red);
    text-shadow:
      -1.5px 0 var(--ink), 1.5px 0 var(--ink), 0 -1.5px var(--ink), 0 1.5px var(--ink),
      0 3px 0 var(--red-deep), 0 5px 0 var(--red-deep),
      0 9px 12px rgba(31, 26, 23, 0.35);
  }
  .al.white {
    color: #fff;
    text-shadow:
      -1.5px 0 var(--ink), 1.5px 0 var(--ink), 0 -1.5px var(--ink), 0 1.5px var(--ink),
      0 3px 0 #b9b9b9, 0 5px 0 #a7a7a7,
      0 9px 12px rgba(31, 26, 23, 0.32);
  }
  .al.flip { transform: scaleX(-1); }

  /* ── FESTIVAL ──────────────────────────────────────────────────── */
  .alogo__festival {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
    margin-left: 6px;
  }
  .alogo__festtext {
    font-family: "Anton", var(--font-heading), sans-serif;
    font-size: clamp(0.95rem, 2.4vw, 1.5rem);
    letter-spacing: 0.22em;
    color: #fff;
    text-shadow: -1px 0 var(--ink), 1px 0 var(--ink), 0 1px var(--ink), 0 2px 0 #a7a7a7, 0 4px 6px rgba(31, 26, 23, 0.3);
    padding-left: 0.22em;
  }
  .alogo__spark {
    width: clamp(20px, 3vw, 28px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--red);
    display: grid;
    place-items: center;
    border: 2px solid #fff;
    box-shadow: 0 3px 0 var(--red-deep), 0 5px 8px rgba(31, 26, 23, 0.25);
  }
  .alogo__spark svg { width: 48%; height: 48%; }

  @media (max-width: 420px) {
    .al { font-size: 2.7rem; }
  }
</style>
