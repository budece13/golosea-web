---
import { business, content } from "../data/golosea";

const path = Astro.url.pathname;
const links = [
  { href: "/#hero", label: "Inicio" },
  { href: "/#encargos", label: "Encargos" },
  { href: "/#galeria", label: "Galería" },
  { href: "/#resenas", label: "Reseñas" },
  { href: "/#mapa", label: "Encuéntranos" },
  { href: "/sobre-golosea", label: "Sobre Golosea" },
  { href: "/festivos", label: "Festivos" },
];
---

<header class="navbar" id="navbar">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label={`${business.name} — inicio`}>
      <svg class="brand-mark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m9.5 7.5-2 2a4.95 4.95 0 1 0 7 7l2-2a4.95 4.95 0 1 0-7-7Z" />
        <path d="M14 6.5v10" /><path d="M10 7.5v10" />
        <path d="m16 7 1-5 1.37.68A3 3 0 0 0 19.7 3H21v1.3c0 .46.1.92.32 1.33L22 7l-5 1" />
        <path d="m8 17-1 5-1.37-.68A3 3 0 0 0 4.3 21H3v-1.3a3 3 0 0 0-.32-1.33L2 17l5-1" />
      </svg>
      <span>{business.name}</span>
    </a>

    <nav class="nav-links" id="navMenu" aria-label="Principal">
      {links.map((l) => (
        <a href={l.href} class:list={["nav-link", { active: l.href === path }]}>{l.label}</a>
      ))}
      <a href="/#encargos" class="nav-cta-mob">{content.cta_text}</a>
      <span class="nav-indicator" aria-hidden="true"></span>
    </nav>

    <div class="nav-right">
      <a href="/#encargos" class="nav-cta">{content.cta_text}</a>
      <button class="nav-toggle" id="navToggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="navMenu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(15, 59, 42, 0.08);
    transition: box-shadow 0.25s ease, background 0.25s ease;
  }
  .navbar.scrolled {
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 4px 20px rgba(15, 59, 42, 0.08);
  }

  .nav-inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.4rem;
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .brand-mark { width: 25px; height: 25px; }

  /* Links centrados en la pantalla (absolutos respecto a la barra) */
  .nav-links {
    position: absolute;
    left: 50%;
    top: 0;
    height: 70px;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .nav-link {
    position: relative;
    font-weight: 600;
    font-size: 0.94rem;
    color: #3b4a42;
    transition: color 0.18s ease;
    white-space: nowrap;
  }
  .nav-link:hover,
  .nav-link.active { color: var(--color-primary); }

  /* ── Palito de caramelo deslizante ── */
  .nav-indicator {
    position: absolute;
    bottom: 14px;
    left: 0;
    width: 0;
    height: 6px;
    border-radius: 999px;
    background: repeating-linear-gradient(45deg, var(--color-primary) 0 6px, #fff 6px 12px);
    box-shadow: 0 3px 7px rgba(232, 69, 90, 0.45), inset 0 0 0 1px rgba(232, 69, 90, 0.3);
    opacity: 0;
    transform: translateX(0);
    transition:
      transform 0.38s cubic-bezier(0.34, 1.45, 0.5, 1),
      width 0.38s cubic-bezier(0.34, 1.45, 0.5, 1),
      opacity 0.2s ease;
    animation: candyFlow 0.8s linear infinite;
    pointer-events: none;
  }
  @keyframes candyFlow {
    to { background-position: 17px 0; }
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: auto;
  }
  .nav-cta {
    background: var(--color-primary);
    color: #fff;
    padding: 10px 20px;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.9rem;
    white-space: nowrap;
    box-shadow: 0 5px 14px rgba(232, 69, 90, 0.25);
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }
  .nav-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 9px 20px rgba(232, 69, 90, 0.34);
    background: var(--color-primary-dark);
  }
  .nav-cta:active { transform: translateY(0); }
  .nav-cta-mob { display: none; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    border: none;
    background: transparent;
    cursor: pointer;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-dark);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }
  .nav-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; }
  .nav-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav-link:focus-visible,
  .nav-cta:focus-visible,
  .nav-cta-mob:focus-visible,
  .brand:focus-visible,
  .nav-toggle:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
    border-radius: 6px;
  }

  /* ── Móvil / tablet: menú desplegable ── */
  @media (max-width: 1080px) {
    .nav-toggle { display: flex; }
    .nav-cta { display: none; }
    .nav-indicator { display: none; }

    .nav-links {
      position: absolute;
      left: 0;
      right: 0;
      top: 100%;
      height: auto;
      transform: none;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: #fff;
      padding: 10px 0 16px;
      border-bottom: 1px solid rgba(15, 59, 42, 0.08);
      box-shadow: 0 14px 26px rgba(15, 59, 42, 0.1);
      clip-path: inset(0 0 100% 0);
      opacity: 0;
      pointer-events: none;
      transition: clip-path 0.28s ease, opacity 0.2s ease;
    }
    .nav-links.open {
      clip-path: inset(0 0 0 0);
      opacity: 1;
      pointer-events: auto;
    }
    .nav-link {
      padding: 14px 1.5rem;
      font-size: 1rem;
    }
    .nav-link.active { background: var(--color-light); }
    .nav-cta-mob {
      display: block;
      margin: 12px 1.5rem 4px;
      text-align: center;
      background: var(--color-primary);
      color: #fff;
      padding: 13px 20px;
      border-radius: 999px;
      font-weight: 700;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .navbar, .nav-link, .nav-cta, .nav-toggle span, .nav-links { transition: none; }
    .nav-indicator { animation: none; transition: opacity 0.2s ease; }
  }
</style>

<script>
  const nav = document.getElementById("navbar");
  const toggle = document.getElementById("navToggle");
  const menu = document.getElementById("navMenu");
  const indicator = menu?.querySelector<HTMLElement>(".nav-indicator");
  const linkEls = [...(menu?.querySelectorAll<HTMLElement>(".nav-link") ?? [])];

  // ── Menú móvil ──
  const setOpen = (open: boolean) => {
    menu?.classList.toggle("open", open);
    toggle?.classList.toggle("open", open);
    toggle?.setAttribute("aria-expanded", String(open));
  };
  toggle?.addEventListener("click", () => setOpen(!menu?.classList.contains("open")));
  linkEls.forEach((l) => l.addEventListener("click", () => setOpen(false)));

  // ── Sombra al hacer scroll ──
  const onScroll = () => nav?.classList.toggle("scrolled", window.scrollY > 8);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  // ── Palito de caramelo deslizante ──
  let activeEl: HTMLElement | null = menu?.querySelector(".nav-link.active") ?? null;

  const place = (el: HTMLElement | null) => {
    if (!el || !indicator || !menu) return;
    const nr = menu.getBoundingClientRect();
    const r = el.getBoundingClientRect();
    indicator.style.width = `${r.width}px`;
    indicator.style.transform = `translateX(${r.left - nr.left}px)`;
    indicator.style.opacity = "1";
  };
  const reset = () => {
    if (activeEl) place(activeEl);
    else if (indicator) indicator.style.opacity = "0";
  };

  linkEls.forEach((l) => l.addEventListener("mouseenter", () => place(l)));
  menu?.addEventListener("mouseleave", reset);

  // scroll-spy: secciones presentes en esta página
  const spy = linkEls
    .map((l) => {
      const m = (l.getAttribute("href") || "").match(/#(.+)$/);
      const sec = m ? document.getElementById(m[1]) : null;
      return sec ? { l, sec } : null;
    })
    .filter((x): x is { l: HTMLElement; sec: HTMLElement } => x !== null);

  const onSpy = () => {
    if (!spy.length) return;
    const y = window.scrollY + 110;
    let cur: HTMLElement | null = null;
    for (const s of spy) if (s.sec.offsetTop <= y) cur = s.l;
    activeEl = cur ?? (menu?.querySelector(".nav-link.active") ?? null);
    if (!menu?.matches(":hover")) reset();
  };

  if (spy.length) {
    onSpy();
    window.addEventListener("scroll", onSpy, { passive: true });
  }
  requestAnimationFrame(reset);
  window.addEventListener("resize", reset);
</script>
