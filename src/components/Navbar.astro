---
import { business, content } from "../data/golosea";

const path = Astro.url.pathname;
const links = [
  { href: "/#hero", label: "Inicio" },
  { href: "/#encargos", label: "Encargos" },
  { href: "/#galeria", label: "Galería" },
  { href: "/#resenas", label: "Reseñas" },
  { href: "/#mapa", label: "Encuéntranos" },
  { href: "/#horario", label: "Horario", icon: "clock" },
  { href: "/sobre-golosea", label: "Sobre Golosea" },
  { href: "/festivos", label: "Festivos" },
];
---

<header class="navbar" id="navbar">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label={`${business.name} — inicio`}>
      <img src="/logo/golosea-logo.png" alt={business.name} class="brand-logo" width="160" height="48" />
    </a>

    <nav class="nav-links" id="navMenu" aria-label="Principal">
      {links.map((l) => (
        <a href={l.href} class:list={["nav-link", { active: l.href === path }]}>
          {(l as any).icon === "clock" && (
            <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" />
            </svg>
          )}
          {l.label}
        </a>
      ))}
      <a href="/#encargos" class="btn btn--primary nav-cta-mob">{content.cta_text}</a>
      <span class="nav-indicator" aria-hidden="true"></span>
    </nav>

    <div class="nav-right">
      <a href="/#encargos" class="btn btn--primary btn--sm nav-cta">{content.cta_text}</a>
      <button class="nav-toggle" id="navToggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="navMenu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 14px 0;
    background: transparent;
    transition: padding 0.25s ease;
  }
  .navbar.scrolled {
    padding: 8px 0;
  }

  /* Píldora flotante con efecto glass */
  .nav-inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    padding: 0 14px 0 20px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    border: 1px solid rgba(255, 255, 255, 0.6);
    box-shadow:
      0 8px 30px rgba(15, 59, 42, 0.1),
      inset 0 1px 1px rgba(255, 255, 255, 0.6);
    transition: background 0.25s ease, box-shadow 0.25s ease;
  }
  .navbar.scrolled .nav-inner {
    background: rgba(255, 255, 255, 0.9);
    box-shadow:
      0 10px 34px rgba(15, 59, 42, 0.16),
      inset 0 1px 1px rgba(255, 255, 255, 0.7);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }
  .brand-logo {
    height: 44px;
    width: auto;
  }

  /* Links centrados en la pantalla (absolutos respecto a la barra) */
  .nav-links {
    position: absolute;
    left: 50%;
    top: 0;
    height: 64px;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-weight: 600;
    font-size: 0.94rem;
    color: #3b4a42;
    transition: color 0.18s ease;
    white-space: nowrap;
  }
  .nav-link:hover,
  .nav-link.active { color: var(--color-primary); }
  .nav-ico {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  /* El relojito del nav gira con pasos de tic-tac al pasar por encima */
  .nav-link:hover .nav-ico { animation: navClockTick 2s steps(12) infinite; }
  @keyframes navClockTick {
    to { transform: rotate(360deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-link:hover .nav-ico { animation: none; }
  }

  /* ── Palito de caramelo deslizante ── */
  .nav-indicator {
    position: absolute;
    bottom: 14px;
    left: 0;
    width: 0;
    height: 6px;
    border-radius: 999px;
    background: repeating-linear-gradient(45deg, var(--color-primary) 0 6px, #fff 6px 12px);
    box-shadow: 0 3px 7px rgba(232, 69, 90, 0.45), inset 0 0 0 1px rgba(232, 69, 90, 0.3);
    opacity: 0;
    transform: translateX(0);
    transition:
      transform 0.38s cubic-bezier(0.34, 1.45, 0.5, 1),
      width 0.38s cubic-bezier(0.34, 1.45, 0.5, 1),
      opacity 0.2s ease;
    animation: candyFlow 0.8s linear infinite;
    pointer-events: none;
  }
  @keyframes candyFlow {
    to { background-position: 17px 0; }
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: auto;
  }
  .nav-cta { white-space: nowrap; }
  .nav-cta-mob { display: none; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    border: none;
    background: transparent;
    cursor: pointer;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-dark);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }
  .nav-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; }
  .nav-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav-link:focus-visible,
  .nav-cta:focus-visible,
  .nav-cta-mob:focus-visible,
  .brand:focus-visible,
  .nav-toggle:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
    border-radius: 6px;
  }

  /* ── Móvil / tablet: menú desplegable ── */
  @media (max-width: 1080px) {
    .nav-toggle { display: flex; }
    .nav-cta { display: none; }
    .nav-indicator { display: none; }

    .nav-links {
      position: absolute;
      left: 0;
      right: 0;
      top: 100%;
      height: auto;
      transform: none;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: #fff;
      padding: 10px 0 16px;
      /* en iPhone pequeño / horizontal el menú puede pasar del alto de pantalla:
         lo limitamos y dejamos que haga scroll interno con inercia iOS */
      max-height: calc(100svh - 90px);
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior: contain;
      border-bottom: 1px solid rgba(15, 59, 42, 0.08);
      box-shadow: 0 14px 26px rgba(15, 59, 42, 0.1);
      clip-path: inset(0 0 100% 0);
      opacity: 0;
      pointer-events: none;
      transition: clip-path 0.28s ease, opacity 0.2s ease;
    }
    .nav-links.open {
      clip-path: inset(0 0 0 0);
      opacity: 1;
      pointer-events: auto;
    }
    .nav-link {
      padding: 14px 1.5rem;
      font-size: 1rem;
    }
    .nav-link.active { background: var(--color-light); }
    .nav-cta-mob {
      display: inline-flex;
      margin: 12px 1.5rem 4px;
    }
  }

  /* ── Móvil: barra más fina y con margen a los lados ── */
  @media (max-width: 600px) {
    .navbar { padding: 10px 12px; }
    .navbar.scrolled { padding: 6px 12px; }
    .nav-inner {
      height: 52px;
      padding: 0 10px 0 14px;
    }
    .brand-logo { height: 34px; }
    .nav-toggle { width: 40px; height: 40px; }
    .nav-links { top: calc(100% + 8px); border-radius: 18px; overflow: hidden; }
  }

  @media (prefers-reduced-motion: reduce) {
    .navbar, .nav-link, .nav-cta, .nav-toggle span, .nav-links { transition: none; }
    .nav-indicator { animation: none; transition: opacity 0.2s ease; }
  }
</style>

<script>
  const nav = document.getElementById("navbar");
  const toggle = document.getElementById("navToggle");
  const menu = document.getElementById("navMenu");
  const indicator = menu?.querySelector<HTMLElement>(".nav-indicator");
  const linkEls = [...(menu?.querySelectorAll<HTMLElement>(".nav-link") ?? [])];

  // ── Menú móvil ──
  const setOpen = (open: boolean) => {
    menu?.classList.toggle("open", open);
    toggle?.classList.toggle("open", open);
    toggle?.setAttribute("aria-expanded", String(open));
  };
  toggle?.addEventListener("click", () => setOpen(!menu?.classList.contains("open")));
  linkEls.forEach((l) => l.addEventListener("click", () => setOpen(false)));

  // ── Sombra al hacer scroll ──
  const onScroll = () => nav?.classList.toggle("scrolled", window.scrollY > 8);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  // ── Palito de caramelo deslizante ──
  let activeEl: HTMLElement | null = menu?.querySelector(".nav-link.active") ?? null;

  const place = (el: HTMLElement | null) => {
    if (!el || !indicator || !menu) return;
    const nr = menu.getBoundingClientRect();
    const r = el.getBoundingClientRect();
    indicator.style.width = `${r.width}px`;
    indicator.style.transform = `translateX(${r.left - nr.left}px)`;
    indicator.style.opacity = "1";
  };
  const reset = () => {
    if (activeEl) place(activeEl);
    else if (indicator) indicator.style.opacity = "0";
  };

  linkEls.forEach((l) => l.addEventListener("mouseenter", () => place(l)));
  menu?.addEventListener("mouseleave", reset);

  // scroll-spy: secciones presentes en esta página
  const spy = linkEls
    .map((l) => {
      const m = (l.getAttribute("href") || "").match(/#(.+)$/);
      const sec = m ? document.getElementById(m[1]) : null;
      return sec ? { l, sec } : null;
    })
    .filter((x): x is { l: HTMLElement; sec: HTMLElement } => x !== null);

  const onSpy = () => {
    if (!spy.length) return;
    const y = window.scrollY + 110;
    let cur: HTMLElement | null = null;
    for (const s of spy) if (s.sec.offsetTop <= y) cur = s.l;
    activeEl = cur ?? (menu?.querySelector(".nav-link.active") ?? null);
    if (!menu?.matches(":hover")) reset();
  };

  if (spy.length) {
    onSpy();
    window.addEventListener("scroll", onSpy, { passive: true });
  }
  requestAnimationFrame(reset);
  window.addEventListener("resize", reset);
</script>
