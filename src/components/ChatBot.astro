---
import { business } from "../data/golosea";
---

<button class="chat-btn" id="chatBtn" aria-label="Abrir chat de Golosea">💬</button>

<div class="chat-panel" id="chatPanel" role="dialog" aria-label="Chat con Golosea">
  <div class="chat-head">
    {business.name}
    <small>Asistente virtual · responde al instante</small>
  </div>
  <div class="chat-body" id="chatBody">
    <div class="msg bot">Hola 👋 Soy el asistente de {business.name}. ¿En qué puedo ayudarte?</div>
  </div>
  <div class="chat-input">
    <input type="text" id="chatInput" placeholder="Escribe tu pregunta..." autocomplete="off" />
    <button id="chatSend">Enviar</button>
  </div>
</div>

<style>
  .chat-btn {
    position: fixed;
    bottom: 22px;
    right: 22px;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    border: none;
    cursor: pointer;
    font-size: 1.6rem;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.25);
    z-index: 60;
    transition: transform 0.15s;
  }

  .chat-btn:hover {
    transform: scale(1.08);
  }

  .chat-panel {
    position: fixed;
    bottom: 90px;
    right: 22px;
    width: 340px;
    max-width: calc(100vw - 44px);
    height: 460px;
    max-height: 70vh;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.25);
    display: none;
    flex-direction: column;
    overflow: hidden;
    z-index: 60;
  }

  .chat-panel.open {
    display: flex;
  }

  .chat-head {
    background: var(--color-primary);
    color: #fff;
    padding: 14px 16px;
    font-weight: 700;
    font-family: var(--font-heading);
    font-size: 1rem;
    flex-shrink: 0;
  }

  .chat-head small {
    display: block;
    font-weight: 400;
    opacity: 0.85;
    font-size: 0.78rem;
    font-family: var(--font-body);
  }

  .chat-body {
    flex: 1;
    overflow-y: auto;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: #f7f8fa;
  }

  .msg {
    max-width: 80%;
    padding: 10px 13px;
    border-radius: 14px;
    font-size: 0.92rem;
    line-height: 1.4;
  }

  .msg.bot {
    background: #fff;
    border: 1px solid #eee;
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }

  .msg.user {
    background: var(--color-primary);
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }

  .chat-input {
    display: flex;
    border-top: 1px solid #eee;
    flex-shrink: 0;
  }

  .chat-input input {
    flex: 1;
    border: none;
    padding: 13px;
    font-size: 0.95rem;
    outline: none;
    font-family: var(--font-body);
  }

  .chat-input button {
    border: none;
    background: var(--color-primary);
    color: #fff;
    padding: 0 18px;
    cursor: pointer;
    font-weight: 700;
    font-family: var(--font-body);
    transition: filter 0.15s;
  }

  .chat-input button:hover {
    filter: brightness(1.1);
  }
</style>

<script>
  const panel = document.getElementById('chatPanel')!;
  const body  = document.getElementById('chatBody')!;
  const input = document.getElementById('chatInput') as HTMLInputElement;
  const history: { role: string; content: string }[] = [];

  document.getElementById('chatBtn')!.addEventListener('click', () => {
    panel.classList.toggle('open');
    if (panel.classList.contains('open')) input.focus();
  });

  function addMsg(text: string, who: 'bot' | 'user') {
    const d = document.createElement('div');
    d.className = `msg ${who}`;
    d.textContent = text;
    body.appendChild(d);
    body.scrollTop = body.scrollHeight;
    return d;
  }

  async function send() {
    const text = input.value.trim();
    if (!text) return;
    addMsg(text, 'user');
    history.push({ role: 'user', content: text });
    input.value = '';
    const typing = addMsg('...', 'bot');
    try {
      const r = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: history }),
      });
      const data = await r.json();
      typing.textContent = data.reply || 'Lo siento, no puedo responder ahora.';
      history.push({ role: 'assistant', content: typing.textContent! });
    } catch {
      typing.textContent = 'Ahora mismo no puedo responder. Prueba a llamarnos.';
    }
  }

  document.getElementById('chatSend')!.addEventListener('click', send);
  input.addEventListener('keydown', (e) => { if (e.key === 'Enter') send(); });
</script>
