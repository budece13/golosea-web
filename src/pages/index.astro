---
// SECCIONES FUTURAS A CREAR:
// - /productos   → Catálogo de golosinas con filtros por tipo
// - /encargos    → Landing de cucuruchos/fiestas + formulario de encargo detallado
// - /fiestas     → Página dedicada a eventos y celebraciones
// - /galeria     → Galería ampliada con fotos propias del negocio
// - /blog        → Novedades, temporadas, recetas con chucherías

import Layout from "../layouts/Layout.astro";
import { content, business, images, heroSlides } from "../data/golosea";
---

<Layout>

  <!-- ═══════════════════════════════════════════
       HERO — slideshow de productos que rota solo
  ═══════════════════════════════════════════ -->
  <section class="hero" id="hero">
    <!-- capas de fondo (una por producto, cambian de color) -->
    <div class="hero-bgs">
      {heroSlides.map((s, i) => (
        <div
          class:list={["hero-bg", { blur: (s as any).blur }]}
          style={`background: ${s.bg}`}
        />
      ))}
    </div>

    <!-- ingredientes de fondo (detras del titulo; 5 por slide, con profundidad) -->
    <div class="hero-decor" aria-hidden="true">
      {heroSlides.map((s, i) => (
        <div class="decor">
          {[1, 0, 0, 1, 1].map((idx) => (
            <img class="ding" src={s.ingredients[idx].src} alt="" loading={i === 0 ? "eager" : "lazy"} />
          ))}
        </div>
      ))}
    </div>

    <!-- titulo (Permanent Marker; rise-out / drop-in por seccion) -->
    <h1 class="hero-title">
      <span class="tl">Dulces que alegran</span>{" "}
      <span class="tl">tu día</span>
    </h1>

    <!-- producto central (delante del titulo), uno por slide -->
    <div class="hero-stage" aria-hidden="true">
      {heroSlides.map((s, i) => (
        <img class="product" src={s.product.src} alt={s.product.alt} loading={i === 0 ? "eager" : "lazy"} />
      ))}
    </div>

    <!-- eyebrow arriba a la izquierda -->
    <p class="hero-eyebrow">El Bonillo</p>

    <!-- pie fijo: parrafo + CTAs -->
    <div class="hero-foot">
      <p class="subtext">{content.hero_subtext}</p>
      <div class="hero-actions">
        <a href="#contacto" class="btn">{content.cta_text} 🍬</a>
        <a href={`tel:${business.phone.replace(/\s/g, "")}`} class="btn btn-outline">📞 {business.phone}</a>
      </div>
    </div>

  </section>

  <!-- ═══════════════════════════════════════════
       ENCARGOS — formulario de cucuruchos -> WhatsApp
  ═══════════════════════════════════════════ -->
  <section id="encargos" class="section encargos-section">
    <div class="container encargos-wrap">
      <div class="encargos-head">
        <p class="eyebrow">Cucuruchos personalizados</p>
        <h2>Encarga tu <span>cucurucho de chuches</span></h2>
        <p class="encargos-sub">
          Perfectos para cumpleaños y fiestas infantiles. Rellena el formulario
          y te confirmamos el pedido al instante por WhatsApp.
        </p>
      </div>

      <form id="encargoForm" class="encargo-form" data-wa={business.whatsapp}>
        <div class="ef-field">
          <label for="ef-nombre">Nombre</label>
          <input id="ef-nombre" name="nombre" type="text" autocomplete="name" required />
        </div>

        <div class="ef-field">
          <label for="ef-email">Correo electrónico <span class="ef-opt">(opcional)</span></label>
          <input id="ef-email" name="email" type="email" autocomplete="email" placeholder="tucorreo@email.com" />
        </div>

        <div class="ef-field">
          <label for="ef-cantidad">Cantidad de cucuruchos</label>
          <input id="ef-cantidad" name="cantidad" type="number" min="1" inputmode="numeric" placeholder="Ej. 12" required />
        </div>

        <div class="ef-field">
          <label for="ef-dia">Día de recogida</label>
          <input id="ef-dia" name="dia" type="date" required />
          <small class="ef-hint">Mínimo 3 días de antelación</small>
        </div>

        <div class="ef-field">
          <label for="ef-hora">Hora de recogida</label>
          <input id="ef-hora" name="hora" type="time" required />
        </div>

        <div class="ef-field ef-full">
          <label for="ef-comentarios">Comentarios <span class="ef-opt">(opcional)</span></label>
          <textarea id="ef-comentarios" name="comentarios" rows="3" placeholder="Colores, temática, alergias, número de niños..."></textarea>
        </div>

        <div class="ef-full ef-actions">
          <button type="submit" class="ef-submit">
            <svg viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
              <path d="M16 3C9 3 3.5 8.5 3.5 15.5c0 2.3.6 4.4 1.7 6.3L3 29l7.4-2.1c1.8 1 3.9 1.5 6 1.5 7 0 12.5-5.5 12.5-12.5S23 3 16 3zm0 22.7c-1.9 0-3.7-.5-5.3-1.4l-.4-.2-4.4 1.2 1.2-4.3-.3-.4c-1-1.6-1.5-3.5-1.5-5.4C5.5 9.6 10.2 5 16 5s10.5 4.6 10.5 10.5S21.8 25.7 16 25.7zm5.8-7.8c-.3-.2-1.9-.9-2.1-1s-.5-.2-.7.2-.8 1-1 1.2-.4.2-.7.1c-1.9-.9-3.1-1.7-4.3-3.8-.3-.6.3-.5.9-1.7.1-.2 0-.4 0-.5l-1-2.4c-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-1 1-1.3 2.3-1.3 3.9 0 2.3 1.7 4.5 1.9 4.8.2.3 3.3 5 8 7 .7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.9-.8 2.1-1.5.3-.8.3-1.4.2-1.5-.1-.2-.3-.3-.6-.4z" />
            </svg>
            Pedir por WhatsApp
          </button>
          <p class="ef-msg" id="efMsg" role="alert" aria-live="polite"></p>
        </div>
      </form>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       GALERÍA
  ═══════════════════════════════════════════ -->
  <section id="galeria" class="gallery-section">
    <div class="gallery-grid">
      {images.gallery.map((img) => (
        <img src={img.url} alt={img.alt} loading="lazy" />
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       RESEÑAS
  ═══════════════════════════════════════════ -->
  <section id="resenas" class="section testimonials-section">
    <div class="container">
      <div class="section-title">
        <h2 style="color:#fff">Lo que dicen nuestros <span>clientes</span></h2>
      </div>
      <div class="testimonials-grid">
        {content.testimonials.map((t) => (
          <figure class="testimonial">
            <blockquote>"{t.text}"</blockquote>
            <figcaption>
              — {t.name} <span class="stars">★★★★★</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       MAPA + contacto
  ═══════════════════════════════════════════ -->
  <section id="mapa" class="section map-section">
    <div class="container">
      <div class="section-title">
        <h2>Dónde <span>estamos</span></h2>
      </div>
      <div class="map-grid">
        <iframe
          class="map-frame"
          src={business.mapsEmbed}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Golosea en el mapa"
        ></iframe>
        <div class="contact-info">
          <h3>{business.name}</h3>
          <p><span class="ci-label">📍</span> {business.address}</p>
          <p><span class="ci-label">📞</span> <a href={`tel:${business.phone.replace(/\s/g,"")}`}>{business.phone}</a></p>
          <p><span class="ci-label">⭐</span> {business.rating} / 5 ({business.ratingsCount} reseñas)</p>
          <p class="contact-hint">Martes a domingo, mañana y tarde · Lunes cerrado.</p>
          <a href="#encargos" class="btn">Hacer un encargo</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       VISITAS DEL MES — registro (placeholder; se conecta al editar)
  ═══════════════════════════════════════════ -->
  <section class="visits-section">
    <div class="container">
      <p class="visits-label">Visitas a la web este mes</p>
      <p class="visits-count" id="visitsCount">—</p>
      <p class="visits-hint">¡Gracias por pasarte por Golosea! 🍬</p>
    </div>
  </section>

</Layout>

<!-- ═══════════════════════════════════════════
     SCRIPT — encargo de cucuruchos -> WhatsApp
═══════════════════════════════════════════ -->
<script>
  const form = document.getElementById('encargoForm') as HTMLFormElement | null;
  const dia = document.getElementById('ef-dia') as HTMLInputElement | null;
  const msg = document.getElementById('efMsg');

  if (form && dia && msg) {
    const pad = (n: number) => String(n).padStart(2, '0');
    const min = new Date();
    min.setDate(min.getDate() + 3);
    const minStr = `${min.getFullYear()}-${pad(min.getMonth() + 1)}-${pad(min.getDate())}`;
    dia.min = minStr;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const f = new FormData(form);
      const diaVal = String(f.get('dia') || '');
      if (diaVal < minStr) {
        msg.textContent = 'La recogida debe ser con al menos 3 días de antelación.';
        msg.className = 'ef-msg err';
        dia.focus();
        return;
      }
      const wa = form.dataset.wa || '';
      const fecha = new Date(diaVal + 'T00:00').toLocaleDateString('es-ES', {
        weekday: 'long', day: 'numeric', month: 'long',
      });
      const lines = [
        '¡Hola! Quiero encargar un cucurucho de chuches 🍬',
        `• Nombre: ${f.get('nombre')}`,
        f.get('email') ? `• Email: ${f.get('email')}` : '',
        `• Cantidad: ${f.get('cantidad')}`,
        `• Recogida: ${fecha} a las ${f.get('hora')}`,
        f.get('comentarios') ? `• Comentarios: ${f.get('comentarios')}` : '',
      ].filter(Boolean);
      const url = `https://wa.me/${wa}?text=${encodeURIComponent(lines.join('\n'))}`;
      window.open(url, '_blank');
      msg.textContent = '✅ Abriendo WhatsApp para confirmar tu pedido...';
      msg.className = 'ef-msg ok';
      form.reset();
    });
  }
</script>

<!-- ═══════════════════════════════════════════
     SCRIPT — contador de visitas del mes
═══════════════════════════════════════════ -->
<script>
  fetch('/api/visits')
    .then((r) => r.json())
    .then((d) => {
      const el = document.getElementById('visitsCount');
      if (el && typeof d.count === 'number') {
        el.textContent = d.count.toLocaleString('es-ES');
      }
    })
    .catch(() => {});
</script>

<style>
  /* ── Helpers ── */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .section {
    padding: 72px 0;
  }

  .section-title {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-title h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: var(--color-dark);
  }

  .section-title span {
    color: var(--color-primary);
  }

  /* ── Botones ── */
  .btn {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 14px 28px;
    border-radius: 999px;
    font-weight: 700;
    font-family: var(--font-body);
    font-size: 1rem;
    border: none;
    cursor: pointer;
    transition: transform 0.15s, filter 0.15s;
    text-decoration: none;
  }

  .btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.05);
  }

  .btn-outline {
    background: transparent;
    border: 2px solid #fff;
    color: #fff;
  }

  /* ── HERO (poster slideshow) ── */
  .hero {
    position: relative;
    overflow: hidden;
    min-height: min(94vh, 880px);
    color: #fff;
    isolation: isolate;
  }

  /* capas de color que rotan */
  .hero-bgs { position: absolute; inset: 0; z-index: 0; }

  .hero-bg {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: slideFade 12s linear infinite;
  }

  /* cada capa entra 3s desfasada (4 x 3s = 12s) */
  .hero-bgs > .hero-bg:nth-child(1) { animation-delay: 0s; }
  .hero-bgs > .hero-bg:nth-child(2) { animation-delay: -9s; }
  .hero-bgs > .hero-bg:nth-child(3) { animation-delay: -6s; }
  .hero-bgs > .hero-bg:nth-child(4) { animation-delay: -3s; }

  /* refresco: fondo oscuro con halo difuminado */
  .hero-bg.blur::after {
    content: "";
    position: absolute;
    inset: -12%;
    background: inherit;
    filter: blur(64px) saturate(1.1);
    opacity: 0.65;
  }

  /* vignette suave para legibilidad sobre cualquier color (z1) */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.18) 0%,
      rgba(0, 0, 0, 0) 26%,
      rgba(0, 0, 0, 0) 58%,
      rgba(0, 0, 0, 0.34) 100%
    );
  }

  /* ── ingredientes de fondo (z2, DETRAS del titulo; 5 por slide con profundidad) ── */
  .hero-decor { position: absolute; inset: 0; z-index: 2; pointer-events: none; }

  .decor {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: decorMove 12s linear infinite;
  }
  .hero-decor > .decor:nth-child(1) { animation-delay: 0s; }
  .hero-decor > .decor:nth-child(2) { animation-delay: -9s; }
  .hero-decor > .decor:nth-child(3) { animation-delay: -6s; }
  .hero-decor > .decor:nth-child(4) { animation-delay: -3s; }

  .ding {
    position: absolute;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 16px 22px rgba(0, 0, 0, 0.3));
  }
  /* dispersos: unos nitidos, otros con blur (profundidad de campo) */
  .ding:nth-child(1) { width: clamp(150px, 19vw, 270px); top: 6%;  left: 3%;  transform: rotate(-12deg); filter: blur(4px); opacity: 0.78; }
  .ding:nth-child(2) { width: clamp(120px, 15vw, 210px); top: 9%;  right: 5%; transform: rotate(9deg); }
  .ding:nth-child(3) { width: clamp(95px, 11vw, 150px);  top: 41%; left: 1%;  transform: rotate(14deg); filter: blur(3px); opacity: 0.82; }
  .ding:nth-child(4) { width: clamp(140px, 17vw, 240px); bottom: 6%; right: 4%; transform: rotate(-8deg); }
  .ding:nth-child(5) { width: clamp(110px, 13vw, 180px); bottom: 7%; left: 6%; transform: rotate(6deg); filter: blur(5px); opacity: 0.7; }

  /* ── titulo (z3, Permanent Marker) ── */
  .hero-title {
    position: absolute;
    z-index: 3;
    top: 19%;
    left: clamp(1.25rem, 5vw, 5rem);
    margin: 0;
    font-family: "Titan One", var(--font-heading);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.96;
    letter-spacing: 0.005em;
    font-size: clamp(2.7rem, 8vw, 7rem);
    color: #fff;
    text-shadow: 0 4px 18px rgba(0, 0, 0, 0.32);
    pointer-events: none;
  }

  .tl {
    display: block;
    transform-origin: left bottom;
    animation: titleCycle 3s linear infinite;
  }
  .tl:nth-child(2) { animation-delay: 0.08s; }

  /* ── producto central (z4, DELANTE del titulo) ── */
  .hero-stage { position: absolute; inset: 0; z-index: 4; pointer-events: none; }

  .product {
    position: absolute;
    top: 52%;
    left: 50%;
    max-height: 66%;
    max-width: 46%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%);
    filter: drop-shadow(0 30px 34px rgba(0, 0, 0, 0.45));
    animation: productSpin 12s linear infinite;
  }
  .hero-stage > .product:nth-child(1) { animation-delay: 0s; }
  .hero-stage > .product:nth-child(2) { animation-delay: -9s; }
  .hero-stage > .product:nth-child(3) { animation-delay: -6s; }
  .hero-stage > .product:nth-child(4) { animation-delay: -3s; }

  /* ── animaciones coordinadas ──
     Ventana comun: SALIDA 20%→25% (acelerando), ENTRADA 95%→100% (frenando).
     Asi, en cada cambio de seccion, lo que sale y lo que entra coinciden en el tiempo. */
  @keyframes slideFade {
    0%   { opacity: 1; }
    20%  { opacity: 1; }
    25%  { opacity: 0; }
    95%  { opacity: 0; }
    100% { opacity: 1; }
  }
  /* titulo: sube y desaparece al salir; cae desde arriba y asienta con squash (3s = 1 seccion) */
  @keyframes titleCycle {
    0%    { opacity: 1; transform: translateY(0) scaleY(1); }
    80%   { opacity: 1; transform: translateY(0) scaleY(1); animation-timing-function: cubic-bezier(0.5, 0, 0.9, 0.4); }
    88%   { opacity: 0; transform: translateY(-46px) scaleY(1.05); }
    89%   { opacity: 0; transform: translateY(-82px) scaleY(0.95); animation-timing-function: cubic-bezier(0.18, 0.72, 0.3, 1); }
    97%   { opacity: 1; transform: translateY(0) scaleY(0.82); }
    98.5% { opacity: 1; transform: translateY(0) scaleY(1.07); }
    100%  { opacity: 1; transform: translateY(0) scaleY(1); }
  }
  /* producto: sale antihorario hacia arriba; entra ladeado horario y se centra */
  @keyframes productSpin {
    0%   { opacity: 1; transform: translate(-50%, -50%) rotate(0deg); }
    20%  { opacity: 1; transform: translate(-50%, -50%) rotate(0deg); animation-timing-function: cubic-bezier(0.5, 0, 0.9, 0.4); }
    25%  { opacity: 0; transform: translate(-50%, calc(-50% - 95px)) rotate(-20deg); }
    94%  { opacity: 0; transform: translate(-50%, calc(-50% - 175px)) rotate(20deg); }
    95%  {
      opacity: 0;
      transform: translate(-50%, calc(-50% - 175px)) rotate(20deg);
      animation-timing-function: cubic-bezier(0.18, 0.72, 0.3, 1);
    }
    100% { opacity: 1; transform: translate(-50%, -50%) rotate(0deg); }
  }
  /* ingredientes de fondo: misma ventana que el producto (entran/salen a la vez), sin girar */
  @keyframes decorMove {
    0%   { opacity: 1; transform: translateY(0); }
    20%  { opacity: 1; transform: translateY(0); animation-timing-function: cubic-bezier(0.5, 0, 0.9, 0.4); }
    25%  { opacity: 0; transform: translateY(-70px); }
    94%  { opacity: 0; transform: translateY(-110px); }
    95%  {
      opacity: 0;
      transform: translateY(-110px);
      animation-timing-function: cubic-bezier(0.18, 0.72, 0.3, 1);
    }
    100% { opacity: 1; transform: translateY(0); }
  }
  /* ── eyebrow (condensed bold) ── */
  .hero-eyebrow {
    position: absolute;
    z-index: 5;
    top: 8.5%;
    left: clamp(1.25rem, 5vw, 5rem);
    margin: 0;
    font-family: "Anton", var(--font-heading);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: clamp(1.7rem, 4.4vw, 3.4rem);
    color: #fff;
    text-shadow: 0 3px 14px rgba(0, 0, 0, 0.3);
  }

  /* ── pie fijo: parrafo + CTAs ── */
  .hero-foot {
    position: absolute;
    z-index: 5;
    left: clamp(1.25rem, 5vw, 5rem);
    bottom: clamp(1.5rem, 5vh, 3.4rem);
    max-width: 440px;
  }

  .subtext {
    font-size: 1.02rem;
    margin: 0 0 22px;
    opacity: 0.96;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.38);
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  @media (max-width: 860px) {
    .hero { min-height: 92vh; }
    .hero-title {
      top: 15%;
      font-size: clamp(1.7rem, 8.5vw, 3.4rem);
    }
    .product { max-height: 44%; max-width: 78%; top: 50%; }
    .ding:nth-child(1) { width: 130px; }
    .ding:nth-child(2) { width: 108px; }
    .ding:nth-child(3) { width: 88px; }
    .ding:nth-child(4) { width: 120px; }
    .ding:nth-child(5) { width: 98px; }
    .hero-foot { max-width: calc(100% - 2.5rem); }
  }

  /* ── GALERÍA ── */
  .gallery-section {
    overflow: hidden;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .gallery-grid img {
    height: 260px;
    width: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .gallery-grid img:hover {
    transform: scale(1.04);
  }

  /* ── TESTIMONIOS ── */
  .testimonials-section {
    background: var(--color-dark);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .testimonial {
    background: rgba(255, 255, 255, 0.06);
    padding: 28px;
    border-radius: 16px;
  }

  .testimonial blockquote {
    font-size: 1.05rem;
    color: #fff;
    margin-bottom: 14px;
    font-style: italic;
    line-height: 1.6;
  }

  .testimonial figcaption {
    font-weight: 600;
    font-size: 0.9rem;
    color: #fff;
  }

  .stars {
    color: var(--color-accent);
    margin-left: 6px;
  }

  /* ── MAPA + contacto ── */
  .map-section {
    background: var(--color-light);
  }

  .map-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 40px;
    align-items: stretch;
  }

  .map-frame {
    width: 100%;
    height: 100%;
    min-height: 380px;
    border: 0;
    border-radius: 18px;
  }

  .contact-info h3 {
    font-size: 1.4rem;
    color: var(--color-dark);
    margin-bottom: 16px;
  }

  .contact-info p {
    margin-bottom: 10px;
    color: #444;
    line-height: 1.5;
