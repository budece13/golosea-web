---
// SECCIONES FUTURAS A CREAR:
// - /productos   → Catálogo de golosinas con filtros por tipo
// - /encargos    → Landing de cucuruchos/fiestas + formulario de encargo detallado
// - /fiestas     → Página dedicada a eventos y celebraciones
// - /galeria     → Galería ampliada con fotos propias del negocio
// - /blog        → Novedades, temporadas, recetas con chucherías

import Layout from "../layouts/Layout.astro";
import Marquee from "../components/Marquee.astro";
import { content, business, images, heroSlides } from "../data/golosea";

// Enlace para dejar reseña. Cuando tengáis el Place ID de Google, cambiadlo por
// https://search.google.com/local/writereview?placeid=XXXX  (lleva directo a escribir).
const reviewUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
  `${business.name} ${business.zona}`,
)}`;
---

<Layout>

  <!-- ═══════════════════════════════════════════
       HERO — slideshow de productos que rota solo
  ═══════════════════════════════════════════ -->
  <section class="hero" id="hero">
    <!-- capas de fondo (una por producto, cambian de color) -->
    <div class="hero-bgs">
      {heroSlides.map((s, i) => (
        <div
          class:list={["hero-bg", { blur: (s as any).blur }]}
          style={`background: ${s.bg}`}
        />
      ))}
    </div>

    <!-- ingredientes de fondo (detras del titulo; 5 por slide, con profundidad) -->
    <div class="hero-decor" aria-hidden="true">
      {heroSlides.map((s, i) => (
        <div class="decor">
          {[1, 0, 0, 1, 1].map((idx) => (
            <img class="ding" src={s.ingredients[idx].src} alt="" loading={i === 0 ? "eager" : "lazy"} />
          ))}
        </div>
      ))}
    </div>

    <!-- titulo (Permanent Marker; rise-out / drop-in por seccion) -->
    <h1 class="hero-title">
      <span class="tl tl-1">Dulces que</span>
      <span class="tl tl-2">Alegran</span>
      <span class="tl tl-3">Tu día</span>
    </h1>

    <!-- producto central (delante del titulo), uno por slide -->
    <div class="hero-stage" aria-hidden="true">
      {heroSlides.map((s, i) => (
        <img class="product" src={s.product.src} alt={s.product.alt} loading={i === 0 ? "eager" : "lazy"} />
      ))}
    </div>

    <!-- eyebrow arriba a la izquierda -->
    <p class="hero-eyebrow">
      <svg class="hero-eyebrow-pin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" />
      </svg>
      El Bonillo
    </p>

    <!-- pie fijo: parrafo + CTAs -->
    <div class="hero-foot">
      <p class="subtext">{content.hero_subtext}</p>
      <div class="hero-actions">
        <a href="#encargos" class="btn btn--primary">{content.cta_text} 🍬</a>
        <a href={`tel:${business.phone.replace(/\s/g, "")}`} class="btn btn--accent">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z" />
          </svg>
          {business.phone}
        </a>
      </div>
    </div>

  </section>

  <!-- ═══════════════════════════════════════════
       ENCARGOS — formulario de cucuruchos -> WhatsApp
  ═══════════════════════════════════════════ -->
  <section id="encargos" class="section encargos-section">
    <div class="encargos-bg" aria-hidden="true">
      <div class="encargos-bg-inner"></div>
    </div>
    <div class="container encargos-wrap">
      <div class="encargos-head">
        <span class="encargos-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9.5 7.5-2 2a4.95 4.95 0 1 0 7 7l2-2a4.95 4.95 0 1 0-7-7Z" />
            <path d="M14 6.5v10" /><path d="M10 7.5v10" />
            <path d="m16 7 1-5 1.37.68A3 3 0 0 0 19.7 3H21v1.3c0 .46.1.92.32 1.33L22 7l-5 1" />
            <path d="m8 17-1 5-1.37-.68A3 3 0 0 0 4.3 21H3v-1.3a3 3 0 0 0-.32-1.33L2 17l5-1" />
          </svg>
          Encargos a tu gusto
        </span>
        <h2>Encarga tu <span class="hl">cucurucho de chuches</span></h2>
        <p class="encargos-sub">
          Perfectos para cumpleaños y fiestas infantiles. Rellena el formulario
          y te confirmamos el pedido al instante por WhatsApp.
        </p>
      </div>

      <div class="form-shell">
        <img
          class="form-cucurucho form-cucurucho--right"
          src="/secciones/cucurucho-final.png"
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
        />
        <img
          class="form-cucurucho form-cucurucho--left"
          src="/secciones/cucurucho-final.png"
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
        />
        <form id="encargoForm" class="encargo-form" data-wa={business.whatsapp}>
          <div class="ef-field ef-full">
            <label for="ef-nombre">
              <svg class="ef-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 3.6-6 8-6s8 2 8 6" /></svg>
              Nombre
            </label>
            <input id="ef-nombre" name="nombre" type="text" autocomplete="name" placeholder="Tu nombre" required />
          </div>

          <div class="ef-field">
            <label for="ef-cantidad">
              <svg class="ef-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 9h16M4 15h16M10 3 8 21M16 3l-2 18" /></svg>
              Cantidad
            </label>
            <input id="ef-cantidad" name="cantidad" type="number" min="1" inputmode="numeric" placeholder="Ej. 12" required />
          </div>

          <div class="ef-field">
            <label for="ef-email">
              <svg class="ef-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2" /><path d="m3 7 9 6 9-6" /></svg>
              Correo <span class="ef-opt">(opcional)</span>
            </label>
            <input id="ef-email" name="email" type="email" autocomplete="email" placeholder="tucorreo@email.com" />
          </div>

          <div class="ef-field">
            <label for="ef-dia">
              <svg class="ef-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" /><path d="M3 10h18M8 2v4M16 2v4" /></svg>
              Día de recogida
            </label>
            <input id="ef-dia" name="dia" type="date" required />
            <small class="ef-hint">Mínimo 3 días de antelación</small>
          </div>

          <div class="ef-field">
            <label for="ef-hora">
              <svg class="ef-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9" /><path d="M12 7.5V12l3 2" /></svg>
              Hora de recogida
            </label>
            <input id="ef-hora" name="hora" type="time" required />
          </div>

          <div class="ef-field ef-full">
            <label for="ef-comentarios">
              <svg class="ef-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H8l-5 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
              Comentarios <span class="ef-opt">(opcional)</span>
            </label>
            <textarea id="ef-comentarios" name="comentarios" rows="3" placeholder="Colores, temática, alergias, número de niños..."></textarea>
          </div>

          <div class="ef-full ef-actions">
            <button type="submit" class="btn btn--whatsapp">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.044zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z" />
            </svg>
            Pedir por WhatsApp
          </button>
            <p class="ef-msg" id="efMsg" role="alert" aria-live="polite"></p>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FRANJAS MARQUEE (entre encargos y galería)
  ═══════════════════════════════════════════ -->
  <div class="marquees">
    <Marquee text="Explora nuestra galería virtual" variant="red" direction="left" />
    <Marquee text="Y conócenos" variant="green" direction="right" />
  </div>

  <!-- ═══════════════════════════════════════════
       GALERÍA
  ═══════════════════════════════════════════ -->
  <section id="galeria" class="section gallery-section">
    <div class="container">
      <div class="gallery-head">
        <span class="gallery-eyebrow">Nuestra galería</span>
        <h2>Un vistazo a nuestras <span class="hl">chuches</span></h2>
        <p class="gallery-sub">
          Cucuruchos, mesas dulces y rincones llenos de color. Échale un ojo
          a algunas de nuestras creaciones favoritas.
        </p>
      </div>
    </div>

    <!-- Carrusel automático (derecha -> izquierda) -->
    <div class="gallery-marquee">
      <div class="gallery-track">
        {images.gallery.map((img) => (
          <figure class="gallery-card">
            <img src={img.url} alt={img.alt} draggable="false" loading="lazy" decoding="async" />
          </figure>
        ))}
        {images.gallery.map((img) => (
          <figure class="gallery-card" aria-hidden="true">
            <img src={img.url} alt="" draggable="false" loading="lazy" decoding="async" />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       RESEÑAS
  ═══════════════════════════════════════════ -->
  <section id="resenas" class="section reviews-section">
    <div class="container">
      <div class="review-cta">
        <div class="review-stars" aria-hidden="true">
          <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
        </div>
        <h2>¿Te has endulzado con <span class="rc-brand">Golosea</span>?</h2>
        <p class="review-lead">
          Tu opinión nos endulza el día y anima a otros golosos a descubrirnos.
          Cuéntale al mundo cuál es tu chuche favorita en una reseña: ¡solo te
          llevará un minuto!
        </p>
        <a href={reviewUrl} target="_blank" rel="noopener noreferrer" class="btn btn--primary review-btn">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z" />
          </svg>
          Déjanos tu reseña
        </a>
        <p class="review-foot">Nos encantará leerte 🍬</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       MAPA + contacto
  ═══════════════════════════════════════════ -->
  <section id="mapa" class="section map-section">
    <div class="container">
      <div class="section-title">
        <span class="section-eyebrow">Visítanos</span>
        <h2>Dónde <span>estamos</span></h2>
        <p class="section-sub">Una esquina con historia en el centro del pueblo</p>
      </div>
      <div class="map-grid">
        <iframe
          class="map-frame"
          src={business.mapsEmbed}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Golosea en el mapa"
        ></iframe>
        <div class="contact-info">
          <h3>Ven a vernos!</h3>
          <ul class="ci-list">
            <li><span class="ci-label">📍</span> <span>{business.address}</span></li>
            <li><span class="ci-label">📞</span> <a href={`tel:${business.phone.replace(/\s/g,"")}`}>{business.phone}</a></li>

            <li><span class="ci-label">🕑</span> <span>Martes a domingo, mañana y tarde · Lunes cerrado.</span></li>
          </ul>
          <a href="#encargos" class="btn btn--primary">Hacer un encargo</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       VISITAS DEL MES — registro (placeholder; se conecta al editar)
  ═══════════════════════════════════════════ -->
  <section class="visits-section">
    <div class="container">
      <p class="visits-label">Visitas a la web este mes</p>
      <p class="visits-count" id="visitsCount">—</p>
      <p class="visits-hint">¡Gracias por pasarte por Golosea! 🍬</p>
    </div>
  </section>

</Layout>

<!-- ═══════════════════════════════════════════
     SCRIPT — encargo de cucuruchos -> WhatsApp
═══════════════════════════════════════════ -->
<script>
  const form = document.getElementById('encargoForm') as HTMLFormElement | null;
  const dia = document.getElementById('ef-dia') as HTMLInputElement | null;
  const msg = document.getElementById('efMsg');

  if (form && dia && msg) {
    const pad = (n: number) => String(n).padStart(2, '0');
    const min = new Date();
    min.setDate(min.getDate() + 3);
    const minStr = `${min.getFullYear()}-${pad(min.getMonth() + 1)}-${pad(min.getDate())}`;
    dia.min = minStr;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const f = new FormData(form);
      const diaVal = String(f.get('dia') || '');
      if (diaVal < minStr) {
        msg.textContent = 'La recogida debe ser con al menos 3 días de antelación.';
        msg.className = 'ef-msg err';
        dia.focus();
        return;
      }
      const wa = form.dataset.wa || '';
      const fecha = new Date(diaVal + 'T00:00').toLocaleDateString('es-ES', {
        weekday: 'long', day: 'numeric', month: 'long',
      });
      const lines = [
        '¡Hola! Quiero encargar un cucurucho de chuches 🍬',
        `• Nombre: ${f.get('nombre')}`,
        f.get('email') ? `• Email: ${f.get('email')}` : '',
        `• Cantidad: ${f.get('cantidad')}`,
        `• Recogida: ${fecha} a las ${f.get('hora')}`,
        f.get('comentarios') ? `• Comentarios: ${f.get('comentarios')}` : '',
      ].filter(Boolean);
      const url = `https://wa.me/${wa}?text=${encodeURIComponent(lines.join('\n'))}`;
      window.open(url, '_blank');
      msg.textContent = '✅ Abriendo WhatsApp para confirmar tu pedido...';
      msg.className = 'ef-msg ok';
      form.reset();
    });
  }
</script>

<!-- ═══════════════════════════════════════════
     SCRIPT — fondo de chuches que se instala con el scroll
═══════════════════════════════════════════ -->
<script>
  const bg = document.querySelector<HTMLElement>('.encargos-bg');
  const sec = document.getElementById('encargos');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (bg && sec && !reduce) {
    let secH = 0;

    const measure = () => {
      // La capa del fondo mide EXACTAMENTE lo que la sección 2:
      // así, al asentarse, la cubre entera y su base toca la galería (sin huecos).
      secH = sec.offsetHeight;
      bg.style.height = secH + 'px';
    };

    let ticking = false;
    const update = () => {
      ticking = false;
      const rect = sec.getBoundingClientRect();
      const vh = window.innerHeight;
      // p anclado a la ALTURA DE LA SECCIÓN (no a la ventana):
      //  p=0  -> la sección asoma por abajo (rect.top = vh), fondo oculto bajo el hero
      //  p>=1 -> la BASE de la sección ha llegado al borde inferior de la ventana
      //          -> fondo ASENTADO.
      const p = (vh - rect.top) / secH;

      if (p >= 1) {
        // Asentado: anclamos el fondo a la sección como ABSOLUTE y lo dejamos
        // scrollear de forma NATIVA (sin JS). Así va 100% sincronizado con las
        // franjas/galería -> estático de verdad, sin micro-rebotes.
        if (bg.style.position !== 'absolute') {
          bg.style.position = 'absolute';
          bg.style.top = '0';
          bg.style.transform = 'none';
        }
        return;
      }

      // Fase de destape (ascensor): capa FIJA gobernada por el scroll.
      if (bg.style.position !== 'fixed') {
        bg.style.position = 'fixed';
        bg.style.top = '0';
      }
      const offset = -secH * (1 - Math.max(0, p));
      bg.style.transform = `translateY(${rect.top + offset}px)`;
    };

    const onScroll = () => {
      if (!ticking) { ticking = true; requestAnimationFrame(update); }
    };
    const onResize = () => { measure(); update(); };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onResize, { passive: true });
    window.addEventListener('load', onResize);  // re-medir tras cargar fuentes/imgs
    measure();
    update();
  }
</script>

<!-- ═══════════════════════════════════════════
     SCRIPT — contador de visitas del mes
═══════════════════════════════════════════ -->
<script>
  fetch('/api/visits')
    .then((r) => r.json())
    .then((d) => {
      const el = document.getElementById('visitsCount');
      if (el && typeof d.count === 'number') {
        el.textContent = d.count.toLocaleString('es-ES');
      }
    })
    .catch(() => {});
</script>

<!-- ═══════════════════════════════════════════
     SCRIPT — galería: auto-scroll + scroll lateral manual
═══════════════════════════════════════════ -->
<script>
  const marquee = document.querySelector<HTMLElement>('.gallery-marquee');
  const track = marquee?.querySelector<HTMLElement>('.gallery-track');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (marquee && track) {
    let half = 0;
    let pos = 0; // posición en FLOAT (scrollLeft se redondea a entero -> perdería el avance sub-píxel)

    const measure = () => {
      half = track.scrollWidth / 2;          // hay 2 sets idénticos
      if (half > 0 && pos === 0) { pos = half; marquee.scrollLeft = pos; } // arranca centrado
    };
    measure();
    window.addEventListener('resize', measure);
    window.addEventListener('load', measure);

    let hovering = false;
    let dragging = false;
    let interactUntil = 0;
    let startX = 0;
    let startScroll = 0;
    const SPEED = 45; // px/s, semilento (derecha -> izquierda)
    let last = 0;

    const tick = (ts: number) => {
      const dt = last ? (ts - last) / 1000 : 0;
      last = ts;
      const auto = !reduce && !hovering && !dragging && ts > interactUntil;

      if (auto) {
        pos += SPEED * dt;
        if (half > 0) {
          if (pos >= half * 1.5) pos -= half;
          else if (pos <= half * 0.5) pos += half;
        }
        marquee.scrollLeft = pos; // pos guarda el decimal -> el avance sí progresa
      } else {
        // el usuario controla: seguimos su scroll y recentramos sin saltos
        pos = marquee.scrollLeft;
        if (half > 0) {
          if (pos >= half * 1.5) { pos -= half; marquee.scrollLeft = pos; startScroll -= half; }
          else if (pos <= half * 0.5) { pos += half; marquee.scrollLeft = pos; startScroll += half; }
        }
      }
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);

    // hover de ratón pausa el auto
    marquee.addEventListener('pointerenter', (e) => { if (e.pointerType === 'mouse') hovering = true; });
    marquee.addEventListener('pointerleave', () => { hovering = false; });

    // scroll nativo (rueda / trackpad / táctil) pausa el auto un momento
    const bump = () => { interactUntil = performance.now() + 1200; };
    marquee.addEventListener('wheel', bump, { passive: true });
    marquee.addEventListener('touchstart', bump, { passive: true });
    marquee.addEventListener('touchmove', bump, { passive: true });

    // arrastre con ratón (el táctil ya hace scroll nativo)
    marquee.addEventListener('pointerdown', (e) => {
      if (e.pointerType !== 'mouse') return;
      dragging = true;
      startX = e.clientX;
      startScroll = marquee.scrollLeft;
      marquee.classList.add('dragging');
      marquee.setPointerCapture(e.pointerId);
    });
    marquee.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      marquee.scrollLeft = startScroll - (e.clientX - startX);
    });
    const endDrag = (e: PointerEvent) => {
      if (!dragging) return;
      dragging = false;
      marquee.classList.remove('dragging');
      try { marquee.releasePointerCapture(e.pointerId); } catch {}
      interactUntil = performance.now() + 1200;
    };
    marquee.addEventListener('pointerup', endDrag);
    marquee.addEventListener('pointercancel', endDrag);
  }
</script>

<style>
  /* ── Helpers ── */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .section {
    padding: 72px 0;
  }

  .section-title {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-title h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: var(--color-dark);
  }

  .section-title span {
    color: var(--color-primary);
  }
  .section-eyebrow {
    display: inline-block;
    margin-bottom: 12px;
    font-family: var(--font-subheading);
    font-weight: 600;
    font-size: 0.82rem;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--color-primary);
  }
  .section-sub {
    max-width: 540px;
    margin: 12px auto 0;
    color: #6b635f;
    font-size: 1.02rem;
    line-height: 1.6;
  }

  /* ── HERO (poster slideshow) ── */
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    min-height: 100svh;
    color: #fff;
    isolation: isolate;
    z-index: 2; /* opaco y por encima del fondo de chuches, que asoma por debajo */
    /* Base OPACA del hero: en el micro-fundido entre slides, las capas quedan
       traslúcidas (~25%); este color tapa las chuches de la sección 2 que viven
       detrás, en vez de dejarlas asomar. Tono oscuro = leve oscurecido al cambiar. */
    background-color: #17110d;
  }

  /* capas de color que rotan */
  .hero-bgs { position: absolute; inset: 0; z-index: 0; }

  .hero-bg {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: slideFade 12s linear infinite;
  }

  /* cada capa entra 3s desfasada (4 x 3s = 12s) */
  .hero-bgs > .hero-bg:nth-child(1) { animation-delay: 0s; }
  .hero-bgs > .hero-bg:nth-child(2) { animation-delay: -9s; }
  .hero-bgs > .hero-bg:nth-child(3) { animation-delay: -6s; }
  .hero-bgs > .hero-bg:nth-child(4) { animation-delay: -3s; }

  /* refresco: fondo oscuro con halo difuminado */
  .hero-bg.blur::after {
    content: "";
    position: absolute;
    inset: -12%;
    background: inherit;
    filter: blur(64px) saturate(1.1);
    opacity: 0.65;
  }

  /* vignette suave para legibilidad sobre cualquier color (z1) */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.18) 0%,
      rgba(0, 0, 0, 0) 26%,
      rgba(0, 0, 0, 0) 58%,
      rgba(0, 0, 0, 0.34) 100%
    );
  }

  /* ── ingredientes de fondo (z2, DETRAS del titulo; 5 por slide con profundidad) ── */
  .hero-decor { position: absolute; inset: 0; z-index: 2; pointer-events: none; }

  .decor {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: decorMove 12s linear infinite;
  }
  .hero-decor > .decor:nth-child(1) { animation-delay: 0s; }
  .hero-decor > .decor:nth-child(2) { animation-delay: -9s; }
  .hero-decor > .decor:nth-child(3) { animation-delay: -6s; }
  .hero-decor > .decor:nth-child(4) { animation-delay: -3s; }

  .ding {
    position: absolute;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 16px 22px rgba(0, 0, 0, 0.3));
  }
  /* dispersos: unos nitidos, otros con blur (profundidad de campo) */
  .ding:nth-child(1) { width: clamp(135px, 16vw, 235px); top: 6%;  left: 3%;  transform: rotate(-7deg);  filter: blur(4px); opacity: 0.78; }
  .ding:nth-child(2) { width: clamp(95px, 11vw, 160px);  top: 9%;  right: 5%; transform: rotate(11deg);  }
  .ding:nth-child(3) { width: clamp(78px, 9vw, 125px);   top: 41%; left: 1%;  transform: rotate(-13deg); filter: blur(3px); opacity: 0.82; }
  .ding:nth-child(4) { width: clamp(195px, 24vw, 345px); bottom: 4%; right: 3%; transform: rotate(5deg);   }
  .ding:nth-child(5) { width: clamp(115px, 14vw, 200px); bottom: 7%; left: 6%; transform: rotate(-10deg); filter: blur(5px); opacity: 0.7; }

  /* ── titulo (z3, Permanent Marker) ── */
  .hero-title {
    position: absolute;
    z-index: 3;
    top: 19%;
    left: clamp(1.25rem, 5vw, 5rem);
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.96;
    letter-spacing: 0.005em;
    font-size: clamp(2.7rem, 8vw, 7rem);
    color: #fff;
    text-shadow: 0 4px 18px rgba(0, 0, 0, 0.32);
    pointer-events: none;
  }

  .tl {
    display: block;
    transform-origin: left bottom;
    animation: titleCycle 3s linear infinite;
  }
  .tl:nth-child(2) { animation-delay: 0.08s; }
  .tl:nth-child(3) { animation-delay: 0.16s; }

  /* titulo: sube y desaparece al salir; cae desde arriba y asienta con squash (3s = 1 seccion) */
  @keyframes titleCycle {
    0%    { opacity: 1; transform: translateY(0) scaleY(1); }
    80%   { opacity: 1; transform: translateY(0) scaleY(1); animation-timing-function: cubic-bezier(0.5, 0, 0.9, 0.4); }
    88%   { opacity: 0; transform: translateY(-46px) scaleY(1.04); }
    89%   { opacity: 0; transform: translateY(-78px) scaleY(0.97); animation-timing-function: cubic-bezier(0.22, 0.7, 0.3, 1); }
    96%   { opacity: 1; transform: translateY(0) scaleY(0.92); animation-timing-function: cubic-bezier(0.34, 1.3, 0.64, 1); }
    100%  { opacity: 1; transform: translateY(0) scaleY(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .tl { animation: none; }
  }

  /* ── producto central (z4, DELANTE del titulo) ── */
  .hero-stage { position: absolute; inset: 0; z-index: 4; pointer-events: none; }

  .product {
    --rest-rot: 5deg;
    position: absolute;
    top: 52%;
    left: 50%;
    max-height: 66%;
    max-width: 46%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%);
    filter: drop-shadow(0 30px 34px rgba(0, 0, 0, 0.45));
    animation: productSpin 12s linear infinite;
  }
  .hero-stage > .product:nth-child(1) { animation-delay: 0s; }
  .hero-stage > .product:nth-child(2) { animation-delay: -9s; }
  .hero-stage > .product:nth-child(3) { animation-delay: -6s; }
  .hero-stage > .product:nth-child(4) { animation-delay: -3s; --rest-rot: -11deg; }

  /* ── animaciones coordinadas ──
     Ventana comun: SALIDA 20%→25% (acelerando), ENTRADA 95%→100% (frenando).
     Asi, en cada cambio de seccion, lo que sale y lo que entra coinciden en el tiempo. */
  @keyframes slideFade {
    0%   { opacity: 1; }
    20%  { opacity: 1; }
    25%  { opacity: 0; }
    95%  { opacity: 0; }
    100% { opacity: 1; }
  }
  /* producto: sale antihorario hacia arriba; entra ladeado horario y se centra */
  @keyframes productSpin {
    0%   { opacity: 1; transform: translate(-50%, -50%) rotate(var(--rest-rot)); }
    20%  { opacity: 1; transform: translate(-50%, -50%) rotate(var(--rest-rot)); animation-timing-function: cubic-bezier(0.5, 0, 0.9, 0.4); }
    25%  { opacity: 0; transform: translate(-50%, calc(-50% - 95px)) rotate(-20deg); }
    94%  { opacity: 0; transform: translate(-50%, calc(-50% - 175px)) rotate(20deg); }
    95%  {
      opacity: 0;
      transform: translate(-50%, calc(-50% - 175px)) rotate(20deg);
      animation-timing-function: cubic-bezier(0.18, 0.72, 0.3, 1);
    }
    100% { opacity: 1; transform: translate(-50%, -50%) rotate(var(--rest-rot)); }
  }
  /* ingredientes de fondo: misma ventana que el producto (entran/salen a la vez), sin girar */
  @keyframes decorMove {
    0%   { opacity: 1; transform: translateY(0); }
    20%  { opacity: 1; transform: translateY(0); animation-timing-function: cubic-bezier(0.5, 0, 0.9, 0.4); }
    25%  { opacity: 0; transform: translateY(-70px); }
    94%  { opacity: 0; transform: translateY(-110px); }
    95%  {
      opacity: 0;
      transform: translateY(-110px);
      animation-timing-function: cubic-bezier(0.18, 0.72, 0.3, 1);
    }
    100% { opacity: 1; transform: translateY(0); }
  }
  /* ── eyebrow (condensed bold) ── */
  .hero-eyebrow {
    position: absolute;
    z-index: 5;
    top: 13.5%;
    left: clamp(1.25rem, 5vw, 5rem);
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-family: var(--font-subheading);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: clamp(1.2rem, 3vw, 2.2rem);
    color: #fff;
    text-shadow: 0 3px 14px rgba(0, 0, 0, 0.3);
  }
  .hero-eyebrow-pin {
    width: 0.95em;
    height: 0.95em;
    flex-shrink: 0;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.3));
  }

  /* ── pie fijo: parrafo + CTAs ── */
  .hero-foot {
    position: absolute;
    z-index: 5;
    left: clamp(1.25rem, 5vw, 5rem);
    bottom: clamp(1.5rem, 5vh, 3.4rem);
    max-width: 440px;
  }

  .subtext {
    font-size: 1.02rem;
    margin: 0 0 22px;
    opacity: 0.96;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.38);
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  @media (max-width: 860px) {
    .hero { min-height: 100vh; min-height: 100svh; }
    .hero-title {
      top: 19%;
      font-size: clamp(1.7rem, 8.5vw, 3.4rem);
    }
    .product { max-height: 44%; max-width: 78%; top: 50%; }
    .ding:nth-child(1) { width: 130px; }
    .ding:nth-child(2) { width: 108px; }
    .ding:nth-child(3) { width: 88px; }
    .ding:nth-child(4) { width: 120px; }
    .ding:nth-child(5) { width: 98px; }
    .hero-foot { max-width: calc(100% - 2.5rem); }
  }

  /* Desktop: titulo a la izquierda, en 3 lineas de ancho parecido */
  @media (min-width: 861px) {
    .hero-title {
      text-align: left;
    }
    .tl { transform-origin: left bottom; }
    .tl-1 { font-size: 0.7em; }
    .tl-2 { font-size: 1.15em; }
    .tl-3 { font-size: 1.35em; }
  }

  /* ── FRANJAS MARQUEE ── */
  .marquees {
    position: relative;
    z-index: 1;          /* por encima del fondo fijo de chuches (encargos z0) */
    /* solapa un pelín la base de la sección 2: tapa cualquier hueco que deje
       el vaivén del fondo flotante, sin dejar espacio vacío */
    margin-top: -16px;
  }

  /* ── GALERÍA ── */
  .gallery-section {
    position: relative;
    z-index: 1; /* por encima del fondo fijo de chuches de la sección 2 */
    overflow: hidden;
    /* el carrusel ya añade aire abajo -> reducimos el de la sección para no dejar hueco */
    padding-bottom: 20px;
  }

  .gallery-head {
    text-align: center;
    max-width: 620px;
    margin: 0 auto 38px;
  }
  .gallery-eyebrow {
    display: inline-block;
    margin-bottom: 12px;
    font-family: var(--font-subheading);
    font-weight: 600;
    font-size: 0.82rem;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--color-primary);
  }
  .gallery-head h2 {
    font-size: clamp(1.8rem, 4.6vw, 2.7rem);
    color: var(--color-dark);
  }
  .gallery-head h2 .hl { color: var(--color-primary); }
  .gallery-sub {
    margin-top: 12px;
    color: #6b635f;
    font-size: 1.02rem;
    line-height: 1.6;
  }

  /* Carrusel de fotos: auto + scroll lateral manual (arrastrar/swipe/rueda) */
  .gallery-marquee {
    overflow-x: auto;
    overflow-y: hidden;
    /* mucho aire abajo: la sombra se desvanece antes del recorte -> sin línea */
    padding: 24px 0 56px;
    cursor: grab;
    touch-action: pan-x;        /* swipe horizontal mueve el carrusel; vertical, la página */
    overscroll-behavior-x: contain;
    scrollbar-width: none;      /* Firefox: oculta la barra */
  }
  .gallery-marquee::-webkit-scrollbar { display: none; } /* WebKit: oculta la barra */
  .gallery-marquee.dragging { cursor: grabbing; }
  .gallery-marquee.dragging .gallery-card:hover { transform: none; }

  .gallery-track {
    display: flex;
    width: max-content;
  }

  /* ── Marco gominola GLOSSY 3D (estilo botón) ── */
  .gallery-card {
    --candy: #e8455a;
    position: relative;
    flex: 0 0 auto;
    margin-right: 22px;        /* margen por tarjeta -> bucle perfecto */
    padding: 14px;
    border-radius: 30px;
    /* volumen 3D: claro arriba -> color -> oscuro abajo, con granos de azúcar encima */
    background-image:
      radial-gradient(rgba(255, 255, 255, 0.7) 0.8px, transparent 1.1px),
      radial-gradient(rgba(255, 255, 255, 0.4) 0.7px, transparent 1px),
      linear-gradient(180deg,
        color-mix(in srgb, var(--candy) 28%, #fff) 0%,
        var(--candy) 46%,
        color-mix(in srgb, var(--candy) 82%, #000) 100%);
    background-size: 9px 9px, 13px 13px, 100% 100%;
    background-position: 0 0, 5px 6px, 0 0;
    box-shadow:
      inset 0 3px 5px rgba(255, 255, 255, 0.85),                       /* sheen superior */
      inset 0 0 0 2px rgba(255, 255, 255, 0.55),                       /* canto glaseado brillante */
      inset 0 -6px 11px rgba(0, 0, 0, 0.28),                           /* bisel inferior (3D) */
      0 16px 32px -8px color-mix(in srgb, var(--candy) 55%, #000),     /* glow de color */
      0 8px 16px rgba(0, 0, 0, 0.18);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  /* reflejo glossy superior, como el de los botones */
  .gallery-card::before {
    content: "";
    position: absolute;
    left: 9px;
    right: 9px;
    top: 8px;
    height: 44%;
    border-radius: 22px 22px 50% 50% / 22px 22px 30px 30px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.6) 0%, rgba(255, 255, 255, 0.08) 70%, rgba(255, 255, 255, 0) 100%);
    pointer-events: none;
  }
  .gallery-card img {
    position: relative;
    display: block;
    width: 360px;
    height: 280px;
    object-fit: cover;
    border-radius: 18px;
    /* aro de azúcar blanco alrededor de la foto + profundidad (queda "incrustada") */
    box-shadow:
      0 0 0 4px rgba(255, 255, 255, 0.92),
      0 5px 14px rgba(0, 0, 0, 0.35);
    user-select: none;
    -webkit-user-drag: none;
  }
  .gallery-card:hover {
    transform: translateY(-7px) scale(1.02);
    box-shadow:
      inset 0 3px 5px rgba(255, 255, 255, 0.95),
      inset 0 0 0 2px rgba(255, 255, 255, 0.7),
      inset 0 -6px 11px rgba(0, 0, 0, 0.3),
      0 24px 46px -8px color-mix(in srgb, var(--candy) 62%, #000),
      0 10px 20px rgba(0, 0, 0, 0.2);
  }
  /* mezcla de gominolas: sandía, pistacho, limón, uva */
  .gallery-card:nth-child(4n + 1) { --candy: #e8455a; }
  .gallery-card:nth-child(4n + 2) { --candy: #18b24c; }
  .gallery-card:nth-child(4n + 3) { --candy: #f6b821; }
  .gallery-card:nth-child(4n + 4) { --candy: #9b5de5; }

  /* ── TESTIMONIOS ── */
  /* ── RESEÑAS (CTA para dejar reseña) ── */
  .reviews-section {
    position: relative;
    z-index: 1;
    overflow: hidden;
    background: var(--color-dark);
  }
  /* halos de color (sandía + verde) detrás del card */
  .reviews-section::before,
  .reviews-section::after {
    content: "";
    position: absolute;
    width: 520px;
    height: 520px;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(20px);
  }
  .reviews-section::before {
    top: -160px;
    left: 50%;
    transform: translateX(-60%);
    background: radial-gradient(circle, rgba(232, 69, 90, 0.22), transparent 68%);
  }
  .reviews-section::after {
    bottom: -200px;
    right: 50%;
    transform: translateX(60%);
    background: radial-gradient(circle, rgba(24, 178, 76, 0.18), transparent 68%);
  }

  .review-cta {
    position: relative;
    max-width: 660px;
    margin: 0 auto;
    text-align: center;
    padding: 50px 44px;
    border-radius: 30px;
    background: linear-gradient(165deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.03));
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.32);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
  }

  .review-stars {
    font-size: 2.5rem;
    letter-spacing: 8px;
    margin-bottom: 18px;
    line-height: 1;
  }
  .review-stars span {
    display: inline-block;
    color: #ffc93c;
    filter: drop-shadow(0 4px 10px rgba(255, 201, 60, 0.45));
    animation: starPop 2.6s ease-in-out infinite;
  }
  .review-stars span:nth-child(2) { animation-delay: 0.12s; }
  .review-stars span:nth-child(3) { animation-delay: 0.24s; }
  .review-stars span:nth-child(4) { animation-delay: 0.36s; }
  .review-stars span:nth-child(5) { animation-delay: 0.48s; }
  @keyframes starPop {
    0%, 100% { transform: translateY(0) scale(1); }
    50%      { transform: translateY(-5px) scale(1.14); }
  }

  .review-cta h2 {
    font-size: clamp(1.7rem, 4.4vw, 2.5rem);
    color: #fff;
    margin-bottom: 14px;
  }
  .review-cta h2 .rc-brand { color: var(--color-primary); }

  .review-lead {
    max-width: 500px;
    margin: 0 auto;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.65;
    font-size: 1.04rem;
  }

  .review-btn {
    margin-top: 28px;
    font-size: 1.05rem;
    padding: 15px 32px;
  }

  .review-foot {
    margin-top: 16px;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.92rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .review-stars span { animation: none; }
  }

  @media (max-width: 600px) {
    .review-cta { padding: 38px 24px; }
  }

  /* ── MAPA + contacto ── */
  .map-section {
    position: relative;
    z-index: 1;
    background: var(--color-light);
  }

  .map-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 40px;
    align-items: stretch;
  }

  .map-frame {
    width: 100%;
    height: 100%;
    min-height: 380px;
    border: 0;
    border-radius: 22px;
    box-shadow: 0 16px 40px rgba(28, 69, 50, 0.16);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 32px 30px;
    background: #fff;
    border-radius: 22px;
    box-shadow: 0 16px 40px rgba(28, 69, 50, 0.1);
  }

  .contact-info h3 {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    color: var(--color-primary);
    margin-bottom: 20px;
  }

  .ci-list {
    list-style: none;
    margin: 0 0 22px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .ci-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: #4a443f;
    line-height: 1.45;
  }

  .ci-label {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: var(--color-light);
    font-size: 0.95rem;
  }

  .ci-list a {
    color: var(--color-primary);
    font-weight: 600;
  }
  .contact-info .btn { align-self: flex-start; }

  /* ── ENCARGOS (formulario -> WhatsApp) ── */
  .encargos-section {
    position: relative;
    z-index: 0;        /* contexto de apilado: su fondo queda DEBAJO del hero (z2) */
    overflow: hidden;
    background: linear-gradient(180deg, #fffaf7 0%, var(--color-light) 100%);
  }
  .encargos-wrap { max-width: 760px; position: relative; z-index: 2; }

  /* ── Fondo de chuches: capa FIJA detrás del hero que baja con el scroll ──
     Vive en el contexto de la sección 2 (z0), por eso queda por debajo del
     hero (z2) y este la tapa. Al subir el hero, la va destapando desde su base.
     El JS controla translateY; el float va en la capa interior. */
  .encargos-bg {
    position: fixed;
    left: 0;
    right: 0;
    top: 0;
    height: 0;         /* el JS le da la altura real de la sección 2 */
    z-index: 1;        /* por encima del degradado de la sección, debajo del form (z2) */
    pointer-events: none;
    will-change: transform;
    transform: translateY(-3000px); /* oculto hasta que el JS lo coloca */
  }
  .encargos-bg-inner {
    position: absolute;
    inset: 0;
  }
  /* Capa base (::before): fondo difuminado solo visible en los bordes */
  .encargos-bg-inner::before,
  .encargos-bg-inner::after {
    content: "";
    position: absolute;
    inset: 0;
    background: url("/secciones/chuches-marco.webp") center / cover no-repeat;
  }
  .encargos-bg-inner::before {
    filter: blur(5px);
