---
// SECCIONES FUTURAS A CREAR:
// - /productos   → Catálogo de golosinas con filtros por tipo
// - /encargos    → Landing de cucuruchos/fiestas + formulario de encargo detallado
// - /fiestas     → Página dedicada a eventos y celebraciones
// - /galeria     → Galería ampliada con fotos propias del negocio
// - /blog        → Novedades, temporadas, recetas con chucherías

import Layout from "../layouts/Layout.astro";
import { content, business, images, heroSlides } from "../data/golosea";
---

<Layout>

  <!-- ═══════════════════════════════════════════
       HERO — slideshow de productos que rota solo
  ═══════════════════════════════════════════ -->
  <section class="hero" id="hero">
    <!-- capas de fondo (una por producto, cambian de color) -->
    <div class="hero-bgs">
      {heroSlides.map((s, i) => (
        <div
          class:list={["hero-bg", { blur: (s as any).blur }]}
          style={`background: ${s.bg}`}
        />
      ))}
    </div>

    <!-- escenario: ingredientes + producto flotando (uno por slide) -->
    <div class="hero-stage" aria-hidden="true">
      {heroSlides.map((s, i) => (
        <div class="stage">
          <img class="ing ing-1" src={s.ingredients[0].src} alt={s.ingredients[0].alt} loading={i === 0 ? "eager" : "lazy"} />
          <img class="ing ing-2" src={s.ingredients[1].src} alt={s.ingredients[1].alt} loading={i === 0 ? "eager" : "lazy"} />
          <img class="product" src={s.product.src} alt={s.product.alt} loading={i === 0 ? "eager" : "lazy"} />
        </div>
      ))}
    </div>

    <!-- contenido fijo encima -->
    <div class="hero-content">
      <p class="tagline">{content.tagline}</p>
      <h1>{content.hero_headline}</h1>
      <p class="subtext">{content.hero_subtext}</p>
      <div class="hero-actions">
        <a href="#contacto" class="btn">{content.cta_text} 🍬</a>
        <a href={`tel:${business.phone.replace(/\s/g, "")}`} class="btn btn-outline">📞 {business.phone}</a>
      </div>
      <div class="hero-dots" aria-hidden="true">
        {heroSlides.map((s) => (
          <span class="dot"><span>{s.label}</span></span>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SERVICIOS
  ═══════════════════════════════════════════ -->
  <section id="servicios" class="section">
    <div class="container">
      <div class="section-title">
        <h2>Nuestros <span>servicios</span></h2>
      </div>
      <div class="grid">
        {content.services.map((s) => (
          <article class="card">
            <div class="card-emoji">{s.emoji}</div>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       NOSOTROS — foto + texto + por qué elegirnos
  ═══════════════════════════════════════════ -->
  <section id="nosotros" class="section about-section">
    <div class="container">
      <div class="about-grid">
        <img
          src={images.about.url}
          alt={images.about.alt}
          loading="lazy"
        />
        <div class="about-text">
          <h2>{content.about_title}</h2>
          <p>{content.about_text}</p>
          <div class="why-grid">
            {content.why_choose.map((w) => (
              <div class="why-item">
                <div class="why-emoji">{w.emoji}</div>
                <div>
                  <h4>{w.title}</h4>
                  <p>{w.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       GALERÍA
  ═══════════════════════════════════════════ -->
  <section class="gallery-section">
    <div class="gallery-grid">
      {images.gallery.map((img) => (
        <img src={img.url} alt={img.alt} loading="lazy" />
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       TESTIMONIOS
  ═══════════════════════════════════════════ -->
  <section id="opiniones" class="section testimonials-section">
    <div class="container">
      <div class="section-title">
        <h2 style="color:#fff">Lo que dicen nuestros <span>clientes</span></h2>
      </div>
      <div class="testimonials-grid">
        {content.testimonials.map((t) => (
          <figure class="testimonial">
            <blockquote>"{t.text}"</blockquote>
            <figcaption>
              — {t.name} <span class="stars">★★★★★</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CONTACTO — info + formulario de lead
  ═══════════════════════════════════════════ -->
  <section id="contacto" class="section contact-section">
    <div class="container">
      <div class="section-title">
        <h2>Pide <span>información</span></h2>
      </div>
      <div class="contact-grid">
        <div class="contact-info">
          <h3>{business.name}</h3>
          <p><span class="ci-label">📍 Dirección:</span><br />{business.address}</p>
          <p><span class="ci-label">📞 Teléfono:</span> <a href={`tel:${business.phone.replace(/\s/g,"")}`}>{business.phone}</a></p>
          <p><span class="ci-label">⭐ Valoración:</span> {business.rating} / 5 ({business.ratingsCount} reseñas)</p>
          <p class="contact-hint">Déjanos tus datos y te contactamos lo antes posible.</p>
        </div>
        <form id="leadForm">
          <input type="text"  name="name"    placeholder="Tu nombre"          required />
          <input type="tel"   name="phone"   placeholder="Tu teléfono"        required />
          <input type="email" name="email"   placeholder="Tu email (opcional)" />
          <textarea           name="message" placeholder="¿En qué podemos ayudarte?"></textarea>
          <button type="submit" class="btn">Enviar mensaje</button>
          <p class="form-msg" id="formMsg"></p>
        </form>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════════ -->
  <footer class="footer">
    <div class="brand">{business.name}</div>
    <p>{business.address}</p>
    <small>Web creada con IA · 2025</small>
  </footer>

</Layout>

<!-- ═══════════════════════════════════════════
     SCRIPT — formulario de contacto
═══════════════════════════════════════════ -->
<script>
  const form = document.getElementById('leadForm') as HTMLFormElement;
  const msg  = document.getElementById('formMsg')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    msg.textContent = 'Enviando...';
    msg.style.color = '#666';
    const data = Object.fromEntries(new FormData(form).entries());
    try {
      const r = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!r.ok) throw new Error();
      msg.textContent = '✅ Gracias, hemos recibido tu mensaje. Te contactaremos pronto.';
      msg.style.color = 'green';
      form.reset();
    } catch {
      msg.textContent = '❌ No se pudo enviar. Inténtalo de nuevo o llámanos.';
      msg.style.color = 'crimson';
    }
  });
</script>

<style>
  /* ── Helpers ── */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .section {
    padding: 72px 0;
  }

  .section-title {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-title h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: var(--color-dark);
  }

  .section-title span {
    color: var(--color-primary);
  }

  /* ── Botones ── */
  .btn {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 14px 28px;
    border-radius: 999px;
    font-weight: 700;
    font-family: var(--font-body);
    font-size: 1rem;
    border: none;
    cursor: pointer;
    transition: transform 0.15s, filter 0.15s;
    text-decoration: none;
  }

  .btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.05);
  }

  .btn-outline {
    background: transparent;
    border: 2px solid #fff;
    color: #fff;
  }

  /* ── HERO (slideshow) ── */
  .hero {
    position: relative;
    overflow: hidden;
    min-height: min(92vh, 820px);
    display: flex;
    align-items: center;
    color: #fff;
    isolation: isolate;
  }

  /* capas de color que rotan */
  .hero-bgs { position: absolute; inset: 0; z-index: 0; }

  .hero-bg {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: slideFade 12s linear infinite;
  }

  /* cada capa entra 3s desfasada (4 x 3s = 12s) */
  .hero-bgs > .hero-bg:nth-child(1) { animation-delay: 0s; }
  .hero-bgs > .hero-bg:nth-child(2) { animation-delay: -9s; }
  .hero-bgs > .hero-bg:nth-child(3) { animation-delay: -6s; }
  .hero-bgs > .hero-bg:nth-child(4) { animation-delay: -3s; }

  /* refresco: fondo oscuro con halo difuminado */
  .hero-bg.blur::after {
    content: "";
    position: absolute;
    inset: -12%;
    background: inherit;
    filter: blur(64px) saturate(1.1);
    opacity: 0.65;
  }

  /* scrim para legibilidad del texto */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.58) 0%,
      rgba(0, 0, 0, 0.32) 40%,
      rgba(0, 0, 0, 0) 68%
    );
  }

  /* escenario de imagenes (a la derecha) */
  .hero-stage {
    position: absolute;
    z-index: 1;
    top: 0;
    right: 0;
    bottom: 0;
    width: 52%;
  }

  .stage {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    animation: stagePop 12s linear infinite;
  }

  .hero-stage > .stage:nth-child(1) { animation-delay: 0s; }
  .hero-stage > .stage:nth-child(2) { animation-delay: -9s; }
  .hero-stage > .stage:nth-child(3) { animation-delay: -6s; }
  .hero-stage > .stage:nth-child(4) { animation-delay: -3s; }

  .product {
    position: absolute;
    top: 50%;
    left: 50%;
    max-height: 76%;
    max-width: 82%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%);
    filter: drop-shadow(0 26px 32px rgba(0, 0, 0, 0.42));
  }

  .ing {
    position: absolute;
    width: clamp(104px, 14vw, 178px);
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 12px 18px rgba(0, 0, 0, 0.4));
  }

  .ing-1 { top: 9%; right: 4%; transform: rotate(6deg); }
  .ing-2 { bottom: 8%; left: 1%; transform: rotate(-7deg); }

  /* ── animaciones del slideshow (CSS puro, sin JS — inmune al throttling de timers) ── */
  @keyframes slideFade {
    0%   { opacity: 1; }
    21%  { opacity: 1; }
    25%  { opacity: 0; }
    96%  { opacity: 0; }
    100% { opacity: 1; }
  }
  @keyframes stagePop {
    0%   { opacity: 1; transform: translateY(0) scale(1); }
    21%  { opacity: 1; transform: translateY(0) scale(1); }
    25%  { opacity: 0; transform: translateY(0) scale(1); }
    96%  { opacity: 0; transform: translateY(30px) scale(0.94); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes dotActive {
    0%   { background: #fff; color: var(--color-dark); }
    21%  { background: #fff; color: var(--color-dark); }
    25%  { background: rgba(255, 255, 255, 0.18); color: #fff; }
    96%  { background: rgba(255, 255, 255, 0.18); color: #fff; }
    100% { background: #fff; color: var(--color-dark); }
  }

  /* contenido fijo encima */
  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .hero-content .tagline,
  .hero-content h1,
  .hero-content .subtext {
    max-width: 540px;
  }

  .tagline {
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.82rem;
    color: #fff;
    opacity: 0.85;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.4rem);
    margin: 0 0 18px;
    color: #fff;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.35);
  }

  .subtext {
    font-size: 1.15rem;
    margin: 0 0 30px;
    opacity: 0.95;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.3);
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  /* indicadores / selector de seccion */
  .hero-dots {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 30px;
  }

  .dot {
    display: inline-block;
    font: inherit;
    font-size: 0.82rem;
    font-weight: 700;
    color: #fff;
    background: rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    padding: 7px 15px;
    backdrop-filter: blur(4px);
    animation: dotActive 12s linear infinite;
  }

  .hero-dots > .dot:nth-child(1) { animation-delay: 0s; }
  .hero-dots > .dot:nth-child(2) { animation-delay: -9s; }
  .hero-dots > .dot:nth-child(3) { animation-delay: -6s; }
  .hero-dots > .dot:nth-child(4) { animation-delay: -3s; }

  @media (prefers-reduced-motion: reduce) {
    /* mantiene la rotacion (crossfade) pero sin el "pop" de entrada */
    .stage { animation-name: slideFade; }
  }

  @media (max-width: 860px) {
    .hero {
      min-height: 86vh;
      align-items: flex-end;
      padding-bottom: 42px;
    }
    .hero::before {
      background: linear-gradient(
        180deg,
        rgba(0, 0, 0, 0.15) 0%,
        rgba(0, 0, 0, 0.3) 45%,
        rgba(0, 0, 0, 0.62) 100%
      );
    }
    .hero-stage { width: 100%; }
    .product { max-height: 52%; top: 34%; }
    .ing { width: 82px; }
    .ing-1 { top: 5%; right: 6%; }
    .ing-2 { top: 27%; left: 4%; bottom: auto; }
    .hero-content .tagline,
    .hero-content h1,
    .hero-content .subtext { max-width: 100%; }
  }

  /* ── SERVICIOS ── */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 24px;
  }

  .card {
    background: var(--color-light);
    border-radius: 16px;
    padding: 28px;
    border: 1px solid #eee;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .card:hover {
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
    transform: translateY(-4px);
  }

  .card-emoji {
    font-size: 2rem;
    margin-bottom: 12px;
  }

  .card h3 {
    margin-bottom: 8px;
    font-size: 1.15rem;
    color: var(--color-dark);
  }

  .card p {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  /* ── NOSOTROS ── */
  .about-section {
    background: var(--color-light);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .about-grid img {
    border-radius: 18px;
    height: 100%;
    object-fit: cover;
    max-height: 420px;
    width: 100%;
  }

  .about-text h2 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    color: var(--color-dark);
    margin-bottom: 16px;
  }

  .about-text > p {
    color: #444;
    margin-bottom: 28px;
    font-size: 1.025rem;
    line-height: 1.7;
  }

  .why-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .why-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .why-emoji {
    font-size: 1.6rem;
    flex-shrink: 0;
  }

  .why-item h4 {
    margin-bottom: 4px;
    font-size: 1rem;
    color: var(--color-dark);
  }

  .why-item p {
    color: #555;
    font-size: 0.9rem;
  }

  /* ── GALERÍA ── */
  .gallery-section {
    overflow: hidden;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .gallery-grid img {
    height: 260px;
    width: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .gallery-grid img:hover {
    transform: scale(1.04);
  }

  /* ── TESTIMONIOS ── */
  .testimonials-section {
    background: var(--color-dark);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .testimonial {
    background: rgba(255, 255, 255, 0.06);
    padding: 28px;
    border-radius: 16px;
  }

  .testimonial blockquote {
    font-size: 1.05rem;
    color: #fff;
    margin-bottom: 14px;
    font-style: italic;
    line-height: 1.6;
  }

  .testimonial figcaption {
    font-weight: 600;
    font-size: 0.9rem;
    color: #fff;
  }

  .stars {
    color: var(--color-accent);
    margin-left: 6px;
  }

  /* ── CONTACTO ── */
  .contact-section {
    background: var(--color-light);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }

  .contact-info h3 {
    font-size: 1.4rem;
    color: var(--color-dark);
    margin-bottom: 16px;
  }

  .contact-info p {
    margin-bottom: 10px;
    color: #444;
    line-height: 1.5;
  }

  .ci-label {
    font-weight: 700;
    color: var(--color-dark);
  }

  .contact-info a {
    color: var(--color-primary);
    font-weight: 600;
  }

  .contact-hint {
    margin-top: 18px;
    color: #666;
    font-style: italic;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  form input,
  form textarea {
    padding: 13px 16px;
    border: 1px solid #ddd;
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.15s;
    background: #fff;
  }

  form input:focus,
  form textarea:focus {
    border-color: var(--color-primary);
  }

  form textarea {
    min-height: 120px;
    resize: vertical;
  }

  form .btn {
    background: var(--color-primary);
    color: #fff;
    align-self: flex-start;
  }

  .form-msg {
    font-size: 0.95rem;
    min-height: 1.4em;
  }

  /* ── FOOTER ── */
  .footer {
    background: var(--color-dark);
    color: #fff;
    text-align: center;
    padding: 32px 20px;
  }

  .brand {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
    margin-bottom: 6px;
  }

  .footer p {
    opacity: 0.8;
    margin-bottom: 4px;
  }

  .footer small {
    opacity: 0.5;
    font-size: 0.8rem;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 760px) {
    .about-grid,
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .gallery-grid img {
      height: 220px;
    }
  }
</style>
