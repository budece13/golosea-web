---
// SECCIONES FUTURAS A CREAR:
// - /productos   → Catálogo de golosinas con filtros por tipo
// - /encargos    → Landing de cucuruchos/fiestas + formulario de encargo detallado
// - /fiestas     → Página dedicada a eventos y celebraciones
// - /galeria     → Galería ampliada con fotos propias del negocio
// - /blog        → Novedades, temporadas, recetas con chucherías

import Layout from "../layouts/Layout.astro";
import { content, business, images, heroSlides } from "../data/golosea";
---

<Layout>

  <!-- ═══════════════════════════════════════════
       HERO — slideshow de productos que rota solo
  ═══════════════════════════════════════════ -->
  <section class="hero" id="hero">
    <!-- capas de fondo (una por producto, cambian de color) -->
    <div class="hero-bgs">
      {heroSlides.map((s, i) => (
        <div
          class:list={["hero-bg", { blur: (s as any).blur }]}
          style={`background: ${s.bg}`}
        />
      ))}
    </div>

    <!-- ingredientes de fondo (detras del titulo; 5 por slide, con profundidad) -->
    <div class="hero-decor" aria-hidden="true">
      {heroSlides.map((s, i) => (
        <div class="decor">
          {[1, 0, 0, 1, 1].map((idx) => (
            <img class="ding" src={s.ingredients[idx].src} alt="" loading={i === 0 ? "eager" : "lazy"} />
          ))}
        </div>
      ))}
    </div>

    <!-- titulo (Permanent Marker; rise-out / drop-in por seccion) -->
    <h1 class="hero-title">
      <span class="tl">Dulces que alegran</span>{" "}
      <span class="tl">tu día</span>
    </h1>

    <!-- producto central (delante del titulo), uno por slide -->
    <div class="hero-stage" aria-hidden="true">
      {heroSlides.map((s, i) => (
        <img class="product" src={s.product.src} alt={s.product.alt} loading={i === 0 ? "eager" : "lazy"} />
      ))}
    </div>

    <!-- eyebrow arriba a la izquierda -->
    <p class="hero-eyebrow">El Bonillo</p>

    <!-- pie fijo: parrafo + CTAs -->
    <div class="hero-foot">
      <p class="subtext">{content.hero_subtext}</p>
      <div class="hero-actions">
        <a href="#contacto" class="btn">{content.cta_text} 🍬</a>
        <a href={`tel:${business.phone.replace(/\s/g, "")}`} class="btn btn-outline">📞 {business.phone}</a>
      </div>
    </div>

  </section>

  <!-- ═══════════════════════════════════════════
       SERVICIOS
  ═══════════════════════════════════════════ -->
  <section id="servicios" class="section">
    <div class="container">
      <div class="section-title">
        <h2>Nuestros <span>servicios</span></h2>
      </div>
      <div class="grid">
        {content.services.map((s) => (
          <article class="card">
            <div class="card-emoji">{s.emoji}</div>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       NOSOTROS — foto + texto + por qué elegirnos
  ═══════════════════════════════════════════ -->
  <section id="nosotros" class="section about-section">
    <div class="container">
      <div class="about-grid">
        <img
          src={images.about.url}
          alt={images.about.alt}
          loading="lazy"
        />
        <div class="about-text">
          <h2>{content.about_title}</h2>
          <p>{content.about_text}</p>
          <div class="why-grid">
            {content.why_choose.map((w) => (
              <div class="why-item">
                <div class="why-emoji">{w.emoji}</div>
                <div>
                  <h4>{w.title}</h4>
                  <p>{w.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       GALERÍA
  ═══════════════════════════════════════════ -->
  <section class="gallery-section">
    <div class="gallery-grid">
      {images.gallery.map((img) => (
        <img src={img.url} alt={img.alt} loading="lazy" />
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       TESTIMONIOS
  ═══════════════════════════════════════════ -->
  <section id="opiniones" class="section testimonials-section">
    <div class="container">
      <div class="section-title">
        <h2 style="color:#fff">Lo que dicen nuestros <span>clientes</span></h2>
      </div>
      <div class="testimonials-grid">
        {content.testimonials.map((t) => (
          <figure class="testimonial">
            <blockquote>"{t.text}"</blockquote>
            <figcaption>
              — {t.name} <span class="stars">★★★★★</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CONTACTO — info + formulario de lead
  ═══════════════════════════════════════════ -->
  <section id="contacto" class="section contact-section">
    <div class="container">
      <div class="section-title">
        <h2>Pide <span>información</span></h2>
      </div>
      <div class="contact-grid">
        <div class="contact-info">
          <h3>{business.name}</h3>
          <p><span class="ci-label">📍 Dirección:</span><br />{business.address}</p>
          <p><span class="ci-label">📞 Teléfono:</span> <a href={`tel:${business.phone.replace(/\s/g,"")}`}>{business.phone}</a></p>
          <p><span class="ci-label">⭐ Valoración:</span> {business.rating} / 5 ({business.ratingsCount} reseñas)</p>
          <p class="contact-hint">Déjanos tus datos y te contactamos lo antes posible.</p>
        </div>
        <form id="leadForm">
          <input type="text"  name="name"    placeholder="Tu nombre"          required />
          <input type="tel"   name="phone"   placeholder="Tu teléfono"        required />
          <input type="email" name="email"   placeholder="Tu email (opcional)" />
          <textarea           name="message" placeholder="¿En qué podemos ayudarte?"></textarea>
          <button type="submit" class="btn">Enviar mensaje</button>
          <p class="form-msg" id="formMsg"></p>
        </form>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════════ -->
  <footer class="footer">
    <div class="brand">{business.name}</div>
    <p>{business.address}</p>
    <small>Web creada con IA · 2025</small>
  </footer>

</Layout>

<!-- ═══════════════════════════════════════════
     SCRIPT — formulario de contacto
═══════════════════════════════════════════ -->
<script>
  const form = document.getElementById('leadForm') as HTMLFormElement;
  const msg  = document.getElementById('formMsg')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    msg.textContent = 'Enviando...';
    msg.style.color = '#666';
    const data = Object.fromEntries(new FormData(form).entries());
    try {
      const r = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!r.ok) throw new Error();
      msg.textContent = '✅ Gracias, hemos recibido tu mensaje. Te contactaremos pronto.';
      msg.style.color = 'green';
      form.reset();
    } catch {
      msg.textContent = '❌ No se pudo enviar. Inténtalo de nuevo o llámanos.';
      msg.style.color = 'crimson';
    }
  });
</script>

<style>
  /* ── Helpers ── */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .section {
    padding: 72px 0;
  }

  .section-title {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-title h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: var(--color-dark);
  }

  .section-title span {
    color: var(--color-primary);
  }

  /* ── Botones ── */
  .btn {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 14px 28px;
    border-radius: 999px;
    font-weight: 700;
    font-family: var(--font-body);
    font-size: 1rem;
    border: none;
    cursor: pointer;
    transition: transform 0.15s, filter 0.15s;
    text-decoration: none;
  }

  .btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.05);
  }

  .btn-outline {
    background: transparent;
    border: 2px solid #fff;
    color: #fff;
  }

  /* ── HERO (poster slideshow) ── */
  .hero {
    position: relative;
    overflow: hidden;
    min-height: min(94vh, 880px);
    color: #fff;
    isolation: isolate;
  }

  /* capas de color que rotan */
  .hero-bgs { position: absolute; inset: 0; z-index: 0; }

  .hero-bg {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: slideFade 12s linear infinite;
  }

  /* cada capa entra 3s desfasada (4 x 3s = 12s) */
  .hero-bgs > .hero-bg:nth-child(1) { animation-delay: 0s; }
  .hero-bgs > .hero-bg:nth-child(2) { animation-delay: -9s; }
  .hero-bgs > .hero-bg:nth-child(3) { animation-delay: -6s; }
  .hero-bgs > .hero-bg:nth-child(4) { animation-delay: -3s; }

  /* refresco: fondo oscuro con halo difuminado */
  .hero-bg.blur::after {
    content: "";
    position: absolute;
    inset: -12%;
    background: inherit;
    filter: blur(64px) saturate(1.1);
    opacity: 0.65;
  }

  /* vignette suave para legibilidad sobre cualquier color (z1) */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.18) 0%,
      rgba(0, 0, 0, 0) 26%,
      rgba(0, 0, 0, 0) 58%,
      rgba(0, 0, 0, 0.34) 100%
    );
  }

  /* ── ingredientes de fondo (z2, DETRAS del titulo; 5 por slide con profundidad) ── */
  .hero-decor { position: absolute; inset: 0; z-index: 2; pointer-events: none; }

  .decor {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: decorMove 12s linear infinite;
  }
  .hero-decor > .decor:nth-child(1) { animation-delay: 0s; }
  .hero-decor > .decor:nth-child(2) { animation-delay: -9s; }
  .hero-decor > .decor:nth-child(3) { animation-delay: -6s; }
  .hero-decor > .decor:nth-child(4) { animation-delay: -3s; }

  .ding {
    position: absolute;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 16px 22px rgba(0, 0, 0, 0.3));
  }
  /* dispersos: unos nitidos, otros con blur (profundidad de campo) */
  .ding:nth-child(1) { width: clamp(150px, 19vw, 270px); top: 6%;  left: 3%;  transform: rotate(-12deg); filter: blur(4px); opacity: 0.78; }
  .ding:nth-child(2) { width: clamp(120px, 15vw, 210px); top: 9%;  right: 5%; transform: rotate(9deg); }
  .ding:nth-child(3) { width: clamp(95px, 11vw, 150px);  top: 41%; left: 1%;  transform: rotate(14deg); filter: blur(3px); opacity: 0.82; }
  .ding:nth-child(4) { width: clamp(140px, 17vw, 240px); bottom: 6%; right: 4%; transform: rotate(-8deg); }
  .ding:nth-child(5) { width: clamp(110px, 13vw, 180px); bottom: 7%; left: 6%; transform: rotate(6deg); filter: blur(5px); opacity: 0.7; }

  /* ── titulo (z3, Permanent Marker) ── */
  .hero-title {
    position: absolute;
    z-index: 3;
    top: 19%;
    left: clamp(1.25rem, 5vw, 5rem);
    margin: 0;
    font-family: "Titan One", var(--font-heading);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 0.96;
    letter-spacing: 0.005em;
    font-size: clamp(2.7rem, 8vw, 7rem);
    color: #fff;
    text-shadow: 0 4px 18px rgba(0, 0, 0, 0.32);
    pointer-events: none;
  }

  .tl {
    display: block;
    transform-origin: left bottom;
    animation: titleCycle 3s linear infinite;
  }
  .tl:nth-child(2) { animation-delay: 0.08s; }

  /* ── producto central (z4, DELANTE del titulo) ── */
  .hero-stage { position: absolute; inset: 0; z-index: 4; pointer-events: none; }

  .product {
    position: absolute;
    top: 52%;
    left: 50%;
    max-height: 66%;
    max-width: 46%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%);
    filter: drop-shadow(0 30px 34px rgba(0, 0, 0, 0.45));
    animation: productSpin 12s linear infinite;
  }
  .hero-stage > .product:nth-child(1) { animation-delay: 0s; }
  .hero-stage > .product:nth-child(2) { animation-delay: -9s; }
  .hero-stage > .product:nth-child(3) { animation-delay: -6s; }
  .hero-stage > .product:nth-child(4) { animation-delay: -3s; }

  /* ── animaciones coordinadas ──
     Ventana comun: SALIDA 20%→25% (acelerando), ENTRADA 95%→100% (frenando).
     Asi, en cada cambio de seccion, lo que sale y lo que entra coinciden en el tiempo. */
  @keyframes slideFade {
    0%   { opacity: 1; }
    20%  { opacity: 1; }
    25%  { opacity: 0; }
    95%  { opacity: 0; }
    100% { opacity: 1; }
  }
  /* titulo: sube y desaparece al salir; cae desde arriba y asienta con squash (3s = 1 seccion) */
  @keyframes titleCycle {
    0%    { opacity: 1; transform: translateY(0) scaleY(1); }
    80%   { opacity: 1; transform: translateY(0) scaleY(1); animation-timing-function: cubic-bezier(0.5, 0, 0.9, 0.4); }
    88%   { opacity: 0; transform: translateY(-46px) scaleY(1.05); }
    89%   { opacity: 0; transform: translateY(-82px) scaleY(0.95); animation-timing-function: cubic-bezier(0.18, 0.72, 0.3, 1); }
    97%   { opacity: 1; transform: translateY(0) scaleY(0.82); }
    98.5% { opacity: 1; transform: translateY(0) scaleY(1.07); }
    100%  { opacity: 1; transform: translateY(0) scaleY(1); }
  }
  /* producto: sale antihorario hacia arriba; entra ladeado horario y se centra */
  @keyframes productSpin {
    0%   { opacity: 1; transform: translate(-50%, -50%) rotate(0deg); }
    20%  { opacity: 1; transform: translate(-50%, -50%) rotate(0deg); animation-timing-function: cubic-bezier(0.5, 0, 0.9, 0.4); }
    25%  { opacity: 0; transform: translate(-50%, calc(-50% - 95px)) rotate(-20deg); }
    94%  { opacity: 0; transform: translate(-50%, calc(-50% - 175px)) rotate(20deg); }
    95%  {
      opacity: 0;
      transform: translate(-50%, calc(-50% - 175px)) rotate(20deg);
      animation-timing-function: cubic-bezier(0.18, 0.72, 0.3, 1);
    }
    100% { opacity: 1; transform: translate(-50%, -50%) rotate(0deg); }
  }
  /* ingredientes de fondo: misma ventana que el producto (entran/salen a la vez), sin girar */
  @keyframes decorMove {
    0%   { opacity: 1; transform: translateY(0); }
    20%  { opacity: 1; transform: translateY(0); animation-timing-function: cubic-bezier(0.5, 0, 0.9, 0.4); }
    25%  { opacity: 0; transform: translateY(-70px); }
    94%  { opacity: 0; transform: translateY(-110px); }
    95%  {
      opacity: 0;
      transform: translateY(-110px);
      animation-timing-function: cubic-bezier(0.18, 0.72, 0.3, 1);
    }
    100% { opacity: 1; transform: translateY(0); }
  }
  /* ── eyebrow (condensed bold) ── */
  .hero-eyebrow {
    position: absolute;
    z-index: 5;
    top: 8.5%;
    left: clamp(1.25rem, 5vw, 5rem);
    margin: 0;
    font-family: "Anton", var(--font-heading);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: clamp(1.7rem, 4.4vw, 3.4rem);
    color: #fff;
    text-shadow: 0 3px 14px rgba(0, 0, 0, 0.3);
  }

  /* ── pie fijo: parrafo + CTAs ── */
  .hero-foot {
    position: absolute;
    z-index: 5;
    left: clamp(1.25rem, 5vw, 5rem);
    bottom: clamp(1.5rem, 5vh, 3.4rem);
    max-width: 440px;
  }

  .subtext {
    font-size: 1.02rem;
    margin: 0 0 22px;
    opacity: 0.96;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.38);
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  @media (max-width: 860px) {
    .hero { min-height: 92vh; }
    .hero-title {
      top: 15%;
      font-size: clamp(1.7rem, 8.5vw, 3.4rem);
    }
    .product { max-height: 44%; max-width: 78%; top: 50%; }
    .ding:nth-child(1) { width: 130px; }
    .ding:nth-child(2) { width: 108px; }
    .ding:nth-child(3) { width: 88px; }
    .ding:nth-child(4) { width: 120px; }
    .ding:nth-child(5) { width: 98px; }
    .hero-foot { max-width: calc(100% - 2.5rem); }
  }

  /* ── SERVICIOS ── */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 24px;
  }

  .card {
    background: var(--color-light);
    border-radius: 16px;
    padding: 28px;
    border: 1px solid #eee;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .card:hover {
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
    transform: translateY(-4px);
  }

  .card-emoji {
    font-size: 2rem;
    margin-bottom: 12px;
  }

  .card h3 {
    margin-bottom: 8px;
    font-size: 1.15rem;
    color: var(--color-dark);
  }

  .card p {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  /* ── NOSOTROS ── */
  .about-section {
    background: var(--color-light);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .about-grid img {
    border-radius: 18px;
    height: 100%;
    object-fit: cover;
    max-height: 420px;
    width: 100%;
  }

  .about-text h2 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    color: var(--color-dark);
    margin-bottom: 16px;
  }

  .about-text > p {
    color: #444;
    margin-bottom: 28px;
    font-size: 1.025rem;
    line-height: 1.7;
  }

  .why-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .why-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .why-emoji {
    font-size: 1.6rem;
    flex-shrink: 0;
  }

  .why-item h4 {
    margin-bottom: 4px;
    font-size: 1rem;
    color: var(--color-dark);
  }

  .why-item p {
    color: #555;
    font-size: 0.9rem;
  }

  /* ── GALERÍA ── */
  .gallery-section {
    overflow: hidden;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .gallery-grid img {
    height: 260px;
    width: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .gallery-grid img:hover {
    transform: scale(1.04);
  }

  /* ── TESTIMONIOS ── */
  .testimonials-section {
    background: var(--color-dark);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .testimonial {
    background: rgba(255, 255, 255, 0.06);
    padding: 28px;
    border-radius: 16px;
  }

  .testimonial blockquote {
    font-size: 1.05rem;
    color: #fff;
    margin-bottom: 14px;
    font-style: italic;
    line-height: 1.6;
  }

  .testimonial figcaption {
    font-weight: 600;
    font-size: 0.9rem;
    color: #fff;
  }

  .stars {
    color: var(--color-accent);
    margin-left: 6px;
  }

  /* ── CONTACTO ── */
  .contact-section {
    background: var(--color-light);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }

  .contact-info h3 {
    font-size: 1.4rem;
    color: var(--color-dark);
    margin-bottom: 16px;
  }

  .contact-info p {
    margin-bottom: 10px;
    color: #444;
    line-height: 1.5;
  }

  .ci-label {
    font-weight: 700;
    color: var(--color-dark);
  }

  .contact-info a {
    color: var(--color-primary);
    font-weight: 600;
  }

  .contact-hint {
    margin-top: 18px;
    color: #666;
    font-style: italic;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  form input,
  form textarea {
    padding: 13px 16px;
    border: 1px solid #ddd;
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.15s;
    background: #fff;
  }

  form input:focus,
  form textarea:focus {
    border-color: var(--color-primary);
  }

  form textarea {
    min-height: 120px;
    resize: vertical;
  }

  form .btn {
    background: var(--color-primary);
    color: #fff;
    align-self: flex-start;
  }

  .form-msg {
    font-size: 0.95rem;
    min-height: 1.4em;
  }

  /* ── FOOTER ── */
  .footer {
    background: var(--color-dark);
    color: #fff;
    text-align: center;
    padding: 32px 20px;
  }

  .brand {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
    margin-bottom: 6px;
  }

  .footer p {
    opacity: 0.8;
    margin-bottom: 4px;
  }

  .footer small {
    opacity: 0.5;
    font-size: 0.8rem;
