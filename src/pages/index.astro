---
// SECCIONES FUTURAS A CREAR:
// - /productos   → Catálogo de golosinas con filtros por tipo
// - /encargos    → Landing de cucuruchos/fiestas + formulario de encargo detallado
// - /fiestas     → Página dedicada a eventos y celebraciones
// - /galeria     → Galería ampliada con fotos propias del negocio
// - /blog        → Novedades, temporadas, recetas con chucherías

import Layout from "../layouts/Layout.astro";
import { content, business, images } from "../data/golosea";
---

<Layout>

  <!-- ═══════════════════════════════════════════
       HERO — imagen de fondo con overlay oscuro
  ═══════════════════════════════════════════ -->
  <section
    class="hero"
    style={`background-image: linear-gradient(rgba(0,0,0,.55), rgba(0,0,0,.55)), url('${images.hero.url}')`}
  >
    <p class="tagline">{content.tagline}</p>
    <h1>{content.hero_headline}</h1>
    <p class="subtext">{content.hero_subtext}</p>
    <div class="hero-actions">
      <a
        href="#contacto"
        class="btn"
      >
        {content.cta_text} 🍬
      </a>
      <a
        href={`tel:${business.phone.replace(/\s/g, "")}`}
        class="btn btn-outline"
      >
        📞 {business.phone}
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SERVICIOS
  ═══════════════════════════════════════════ -->
  <section id="servicios" class="section">
    <div class="container">
      <div class="section-title">
        <h2>Nuestros <span>servicios</span></h2>
      </div>
      <div class="grid">
        {content.services.map((s) => (
          <article class="card">
            <div class="card-emoji">{s.emoji}</div>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       NOSOTROS — foto + texto + por qué elegirnos
  ═══════════════════════════════════════════ -->
  <section id="nosotros" class="section about-section">
    <div class="container">
      <div class="about-grid">
        <img
          src={images.about.url}
          alt={images.about.alt}
          loading="lazy"
        />
        <div class="about-text">
          <h2>{content.about_title}</h2>
          <p>{content.about_text}</p>
          <div class="why-grid">
            {content.why_choose.map((w) => (
              <div class="why-item">
                <div class="why-emoji">{w.emoji}</div>
                <div>
                  <h4>{w.title}</h4>
                  <p>{w.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       GALERÍA
  ═══════════════════════════════════════════ -->
  <section class="gallery-section">
    <div class="gallery-grid">
      {images.gallery.map((img) => (
        <img src={img.url} alt={img.alt} loading="lazy" />
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       TESTIMONIOS
  ═══════════════════════════════════════════ -->
  <section id="opiniones" class="section testimonials-section">
    <div class="container">
      <div class="section-title">
        <h2 style="color:#fff">Lo que dicen nuestros <span>clientes</span></h2>
      </div>
      <div class="testimonials-grid">
        {content.testimonials.map((t) => (
          <figure class="testimonial">
            <blockquote>"{t.text}"</blockquote>
            <figcaption>
              — {t.name} <span class="stars">★★★★★</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CONTACTO — info + formulario de lead
  ═══════════════════════════════════════════ -->
  <section id="contacto" class="section contact-section">
    <div class="container">
      <div class="section-title">
        <h2>Pide <span>información</span></h2>
      </div>
      <div class="contact-grid">
        <div class="contact-info">
          <h3>{business.name}</h3>
          <p><span class="ci-label">📍 Dirección:</span><br />{business.address}</p>
          <p><span class="ci-label">📞 Teléfono:</span> <a href={`tel:${business.phone.replace(/\s/g,"")}`}>{business.phone}</a></p>
          <p><span class="ci-label">⭐ Valoración:</span> {business.rating} / 5 ({business.ratingsCount} reseñas)</p>
          <p class="contact-hint">Déjanos tus datos y te contactamos lo antes posible.</p>
        </div>
        <form id="leadForm">
          <input type="text"  name="name"    placeholder="Tu nombre"          required />
          <input type="tel"   name="phone"   placeholder="Tu teléfono"        required />
          <input type="email" name="email"   placeholder="Tu email (opcional)" />
          <textarea           name="message" placeholder="¿En qué podemos ayudarte?"></textarea>
          <button type="submit" class="btn">Enviar mensaje</button>
          <p class="form-msg" id="formMsg"></p>
        </form>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════════ -->
  <footer class="footer">
    <div class="brand">{business.name}</div>
    <p>{business.address}</p>
    <small>Web creada con IA · 2025</small>
  </footer>

</Layout>

<!-- ═══════════════════════════════════════════
     SCRIPT — formulario de contacto
═══════════════════════════════════════════ -->
<script>
  const form = document.getElementById('leadForm') as HTMLFormElement;
  const msg  = document.getElementById('formMsg')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    msg.textContent = 'Enviando...';
    msg.style.color = '#666';
    const data = Object.fromEntries(new FormData(form).entries());
    try {
      const r = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!r.ok) throw new Error();
      msg.textContent = '✅ Gracias, hemos recibido tu mensaje. Te contactaremos pronto.';
      msg.style.color = 'green';
      form.reset();
    } catch {
      msg.textContent = '❌ No se pudo enviar. Inténtalo de nuevo o llámanos.';
      msg.style.color = 'crimson';
    }
  });
</script>

<style>
  /* ── Helpers ── */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .section {
    padding: 72px 0;
  }

  .section-title {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-title h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: var(--color-dark);
  }

  .section-title span {
    color: var(--color-primary);
  }

  /* ── Botones ── */
  .btn {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 14px 28px;
    border-radius: 999px;
    font-weight: 700;
    font-family: var(--font-body);
    font-size: 1rem;
    border: none;
    cursor: pointer;
    transition: transform 0.15s, filter 0.15s;
    text-decoration: none;
  }

  .btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.05);
  }

  .btn-outline {
    background: transparent;
    border: 2px solid #fff;
    color: #fff;
  }

  /* ── HERO ── */
  .hero {
    color: #fff;
    text-align: center;
    padding: 120px 1.25rem 90px;
    background-size: cover;
    background-position: center;
  }

  .tagline {
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 12px;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.4rem);
    max-width: 800px;
    margin: 0 auto 18px;
    color: #fff;
  }

  .subtext {
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto 30px;
    opacity: 0.95;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── SERVICIOS ── */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 24px;
  }

  .card {
    background: var(--color-light);
    border-radius: 16px;
    padding: 28px;
    border: 1px solid #eee;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .card:hover {
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
    transform: translateY(-4px);
  }

  .card-emoji {
    font-size: 2rem;
    margin-bottom: 12px;
  }

  .card h3 {
    margin-bottom: 8px;
    font-size: 1.15rem;
    color: var(--color-dark);
  }

  .card p {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  /* ── NOSOTROS ── */
  .about-section {
    background: var(--color-light);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .about-grid img {
    border-radius: 18px;
    height: 100%;
    object-fit: cover;
    max-height: 420px;
    width: 100%;
  }

  .about-text h2 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    color: var(--color-dark);
    margin-bottom: 16px;
  }

  .about-text > p {
    color: #444;
    margin-bottom: 28px;
    font-size: 1.025rem;
    line-height: 1.7;
  }

  .why-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .why-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .why-emoji {
    font-size: 1.6rem;
    flex-shrink: 0;
  }

  .why-item h4 {
    margin-bottom: 4px;
    font-size: 1rem;
    color: var(--color-dark);
  }

  .why-item p {
    color: #555;
    font-size: 0.9rem;
  }

  /* ── GALERÍA ── */
  .gallery-section {
    overflow: hidden;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .gallery-grid img {
    height: 260px;
    width: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .gallery-grid img:hover {
    transform: scale(1.04);
  }

  /* ── TESTIMONIOS ── */
  .testimonials-section {
    background: var(--color-dark);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .testimonial {
    background: rgba(255, 255, 255, 0.06);
    padding: 28px;
    border-radius: 16px;
  }

  .testimonial blockquote {
    font-size: 1.05rem;
    color: #fff;
    margin-bottom: 14px;
    font-style: italic;
    line-height: 1.6;
  }

  .testimonial figcaption {
    font-weight: 600;
    font-size: 0.9rem;
    color: #fff;
  }

  .stars {
    color: var(--color-accent);
    margin-left: 6px;
  }

  /* ── CONTACTO ── */
  .contact-section {
    background: var(--color-light);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }

  .contact-info h3 {
    font-size: 1.4rem;
    color: var(--color-dark);
    margin-bottom: 16px;
  }

  .contact-info p {
    margin-bottom: 10px;
    color: #444;
    line-height: 1.5;
  }

  .ci-label {
    font-weight: 700;
    color: var(--color-dark);
  }

  .contact-info a {
    color: var(--color-primary);
    font-weight: 600;
  }

  .contact-hint {
    margin-top: 18px;
    color: #666;
    font-style: italic;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  form input,
  form textarea {
    padding: 13px 16px;
    border: 1px solid #ddd;
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.15s;
    background: #fff;
  }

  form input:focus,
  form textarea:focus {
    border-color: var(--color-primary);
  }

  form textarea {
    min-height: 120px;
    resize: vertical;
  }

  form .btn {
    background: var(--color-primary);
    color: #fff;
    align-self: flex-start;
  }

  .form-msg {
    font-size: 0.95rem;
    min-height: 1.4em;
  }

  /* ── FOOTER ── */
  .footer {
    background: var(--color-dark);
    color: #fff;
    text-align: center;
    padding: 32px 20px;
  }

  .brand {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
    margin-bottom: 6px;
  }

  .footer p {
    opacity: 0.8;
    margin-bottom: 4px;
  }

  .footer small {
    opacity: 0.5;
    font-size: 0.8rem;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 760px) {
    .about-grid,
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .gallery-grid img {
      height: 220px;
    }

    .hero {
      padding: 90px 1.25rem 70px;
    }
  }
</style>
