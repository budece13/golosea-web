---
import Layout from "../layouts/Layout.astro";
import Windmill from "../components/festival/Windmill.astro";
import Bunting from "../components/festival/Bunting.astro";
import AlternaLogo from "../components/festival/AlternaLogo.astro";
import { business, images } from "../data/golosea";
import { festividades } from "../data/festividades";

const festival = festividades.find((f) => f.active);
if (!festival) return Astro.redirect("/");

const isManchego = festival.theme === "manchego";

const [from, to] = festival.galeriaSlice;
const galeriaFotos = images.gallery.slice(from, to);

// Foto del intro: la propia de la festividad si existe, si no la primera de la galería
const introImg = festival.imagenIntro ?? galeriaFotos[0];

const waText = encodeURIComponent(
  `Hola! Me paso por Golosea para el ${festival.nombre}. ¿Tenéis todo preparado?`
);
const waUrl = `https://wa.me/${business.whatsapp}?text=${waText}`;
const mapsUrl = `https://maps.google.com/?q=${encodeURIComponent(business.address)}`;

// Línea del cartel duplicada para el ticker continuo
const cartelLine = festival.cartel.join("   ✦   ");
---

<Layout title={festival.seoTitle} description={festival.seoDescription}>

  <!-- ═══════════════════════════════════ 1 · HERO (escena manchega) ══ -->
  <section class:list={["fhero", { "fhero--manchego": isManchego }]}>
    {isManchego && (
      <div class="fhero__scene" aria-hidden="true">
        <span class="cloud cloud--1"></span>
        <span class="cloud cloud--2"></span>
        <span class="cloud cloud--3"></span>
        <span class="sun"></span>
        <div class="fhero__hills"></div>
        <div class="fhero__skyline">
          <Windmill class="wm wm--back" width={120} spin={26} />
          <Windmill class="wm wm--left" width={170} spin={19} reverse />
          <Windmill class="wm wm--right" width={210} spin={15} />
          <Windmill class="wm wm--far" width={96} spin={30} reverse />
        </div>
      </div>
    )}

    <div class="container fhero__content">
      <p class="fhero__eyebrow">{festival.subtitulo}</p>
      {isManchego && <AlternaLogo class="fhero__logo" />}
      <h1 class:list={["fhero__title", { "fhero__title--sub": isManchego }]}>
        {festival.tagline}
      </h1>
      <p class="fhero__lead">{festival.pitchGolosea}</p>
      <div class="fhero__ctas">
        <a href={waUrl} class="btn btn--whatsapp" target="_blank" rel="noopener noreferrer">
          📲 Resérvalo por WhatsApp
        </a>
        <a href={mapsUrl} class="btn btn--ghost" target="_blank" rel="noopener noreferrer">
          📍 Cómo llegar
        </a>
      </div>
    </div>
  </section>

  <Bunting />

  <!-- ═══════════════════════════════════ 2 · BANNER PRECIO ══════════ -->
  <section class="precio-banner">
    <div class="container precio-banner__inner">
      <span class="precio-tag">🏷️</span>
      <div>
        <h2 class="precio-claim">{festival.precioClaim}</h2>
        <p class="precio-sub">{festival.precioSub}</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ 3 · INTRO + SEO ════════════ -->
  <section class="section fest-intro">
    <div class="container fest-intro__grid">
      <div class="fest-intro__text">
        <p class="section-eyebrow">Sobre el festival</p>
        <h2 class="h2-dark">El Alterna Festival vuelve a El Bonillo</h2>
        {festival.descripcionFestival.split("\n").filter(Boolean).map((p) => (
          <p class="prose-p">{p}</p>
        ))}
        <a href={waUrl} class="btn btn--primary" target="_blank" rel="noopener noreferrer">
          Avísanos que vienes {festival.emoji}
        </a>
      </div>
      <div class="fest-intro__media">
        {isManchego && <Windmill class="fest-intro__wm" width={120} spin={22} />}
        <img
          src={introImg?.url}
          alt={introImg?.alt}
          width="560"
          height="420"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ 4 · CARTEL (ticker) ════════ -->
  {festival.cartel.length > 0 && (
    <section class="cartel" aria-label="Cartel del festival">
      <div class="cartel__head container">
        <span class="cartel__kicker">Suena en La Nación</span>
      </div>
      <div class="cartel__ticker">
        <div class="cartel__track">
          <span>{cartelLine}</span>
          <span aria-hidden="true">{cartelLine}</span>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════ 5 · OFERTA ═════════════════ -->
  <section class="section fest-oferta">
    <div class="container">
      <p class="section-eyebrow section-eyebrow--light">Lo que tienes en Golosea</p>
      <h2 class="h2-light">Bebida fría, mezcla, hielo y picoteo</h2>
      <div class="oferta-grid">
        {festival.oferta.map((item) => (
          <article class="oferta-card">
            <span class="oferta-emoji" aria-hidden="true">{item.emoji}</span>
            <h3>{item.titulo}</h3>
            <p>{item.descripcion}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ 6 · POR QUÉ ════════════════ -->
  <section class="section fest-why">
    <div class="container">
      <p class="section-eyebrow">La diferencia</p>
      <h2 class="h2-dark">¿Por qué parar en Golosea?</h2>
      <div class="why-grid">
        {festival.beneficios.map((b) => (
          <div class="why-card">
            <span class="why-emoji" aria-hidden="true">{b.emoji}</span>
            <div class="why-text">
              <strong>{b.titulo}</strong>
              <p>{b.texto}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ 7 · GALERÍA ════════════════ -->
  <section class="section fest-gallery">
    <div class="container">
      <p class="section-eyebrow">La tienda</p>
      <h2 class="h2-dark">Lo tienes todo aquí</h2>
      <div class="gallery-grid">
        {galeriaFotos.map((img) => (
          <figure class="gallery-fig">
            <img src={img.url} alt={img.alt} width="360" height="270" loading="lazy" />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <Bunting flip />

  <!-- ═══════════════════════════════════ 8 · CTA FINAL ══════════════ -->
  <section class:list={["fest-cta", { "fest-cta--manchego": isManchego }]}>
    {isManchego && (
      <div class="fest-cta__scene" aria-hidden="true">
        <span class="cloud cloud--1"></span>
        <span class="cloud cloud--3"></span>
        <div class="fest-cta__skyline">
          <Windmill class="wm wm--cta-left" width={130} spin={21} reverse />
          <Windmill class="wm wm--cta-right" width={160} spin={17} />
        </div>
      </div>
    )}
    <div class="container fest-cta__inner">
      <p class="fest-cta__pre">Antes del primer acorde</p>
      <h2 class="fest-cta__h2">Pásate por Golosea</h2>
      <p class="fest-cta__addr">{business.address}</p>
      <div class="fest-cta__btns">
        <a href={waUrl} class="btn btn--whatsapp" target="_blank" rel="noopener noreferrer">
          📲 WhatsApp
        </a>
        <a href={mapsUrl} class="btn btn--ghost-dark" target="_blank" rel="noopener noreferrer">
          📍 Cómo llegar
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ═══ SHARED ═══════════════════════════════════════════════════════ */
  .section { padding: 78px 0; }
  .section-eyebrow {
    display: block;
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 8px;
  }
  .section-eyebrow--light { color: #ffd0d7; }
  .h2-dark {
    font-size: clamp(1.6rem, 3.6vw, 2.5rem);
    color: var(--color-dark);
    line-height: 1.12;
    margin-bottom: 32px;
  }
  .h2-light {
    font-size: clamp(1.6rem, 3.6vw, 2.5rem);
    color: #fff;
    line-height: 1.12;
    margin-bottom: 36px;
  }

  /* ═══ 1 · HERO ═════════════════════════════════════════════════════ */
  .fhero {
    position: relative;
    overflow: hidden;
    padding: 150px 0 240px;
    color: #14202b;
  }
  .fhero--manchego {
    background: linear-gradient(180deg, #2f8fd4 0%, #56b0e6 42%, #8fd2f4 78%, #c7ecfb 100%);
  }
  .fhero__scene { position: absolute; inset: 0; z-index: 0; pointer-events: none; }

  /* sol */
  .sun {
    position: absolute;
    top: 64px; right: 9%;
    width: 90px; height: 90px;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 50%, #fff3b0 0%, #ffe066 60%, #ffd23f 100%);
    box-shadow: 0 0 0 14px rgba(255, 224, 102, 0.25), 0 0 60px rgba(255, 210, 63, 0.5);
  }

  /* nubes */
  .cloud {
    position: absolute;
    background: #fff;
    border-radius: 100px;
    opacity: 0.96;
    filter: drop-shadow(0 6px 8px rgba(20, 60, 90, 0.08));
  }
  .cloud::before, .cloud::after {
    content: ""; position: absolute; background: #fff; border-radius: 50%;
  }
  .cloud--1 {
    width: 120px; height: 34px; top: 88px; left: -140px;
    animation: drift 48s linear infinite;
  }
  .cloud--1::before { width: 52px; height: 52px; top: -24px; left: 18px; }
  .cloud--1::after  { width: 38px; height: 38px; top: -16px; left: 60px; }
  .cloud--2 {
    width: 90px; height: 26px; top: 150px; left: -120px;
    animation: drift 66s linear infinite; animation-delay: -20s; opacity: 0.85;
  }
  .cloud--2::before { width: 40px; height: 40px; top: -20px; left: 14px; }
  .cloud--2::after  { width: 30px; height: 30px; top: -12px; left: 46px; }
  .cloud--3 {
    width: 150px; height: 40px; top: 50px; left: -180px;
    animation: drift 80s linear infinite; animation-delay: -40s; opacity: 0.9;
  }
  .cloud--3::before { width: 64px; height: 64px; top: -30px; left: 24px; }
  .cloud--3::after  { width: 46px; height: 46px; top: -20px; left: 74px; }
  @keyframes drift { to { transform: translateX(calc(100vw + 320px)); } }

  /* colinas */
  .fhero__hills {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 210px;
    background:
      radial-gradient(120% 80% at 18% 100%, #7cc04a 0 40%, transparent 41%),
      radial-gradient(120% 80% at 82% 100%, #6fb441 0 40%, transparent 41%),
      linear-gradient(180deg, #8fcf5a 0%, #6fb441 100%);
  }

  /* fila de molinos */
  .fhero__skyline {
    position: absolute;
    left: 0; right: 0; bottom: 70px;
    height: 230px;
  }
  .fhero__skyline .wm { position: absolute; bottom: 0; }
  .wm--far   { left: 6%;  bottom: 40px; opacity: 0.85; }
  .wm--back  { left: 22%; bottom: 18px; }
  .wm--left  { left: 40%; bottom: 0; }
  .wm--right { right: 8%; bottom: -6px; }

  .fhero__content { position: relative; z-index: 2; max-width: 660px; }
  .fhero__eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #1f1a17;
    background: #fff;
    border: 2.5px solid #1f1a17;
    border-radius: 100px;
    padding: 7px 18px;
    margin-bottom: 22px;
    box-shadow: 4px 4px 0 #E8455A;
  }
  .fhero__title {
    font-family: var(--font-heading);
    font-size: clamp(2.6rem, 7vw, 4.6rem);
    line-height: 0.98;
    color: #fff;
    margin-bottom: 20px;
    text-shadow: 4px 4px 0 #1f1a17, 0 10px 24px rgba(31, 26, 23, 0.25);
  }
  /* Cuando el logo Alterna es el protagonista, el tagline pasa a apoyo */
  .fhero__logo { margin-bottom: 22px; }
  .fhero__title--sub {
    font-family: var(--font-subheading);
    font-weight: 700;
    font-size: clamp(1.25rem, 3vw, 1.85rem);
    line-height: 1.15;
    color: #15303f;
    text-shadow: 0 2px 0 rgba(255, 255, 255, 0.45);
    margin-bottom: 18px;
    max-width: 520px;
  }
  .fhero__lead {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: clamp(1rem, 2.1vw, 1.18rem);
    line-height: 1.6;
    color: #15303f;
    max-width: 560px;
    margin-bottom: 32px;
  }
  .fhero__ctas { display: flex; flex-wrap: wrap; gap: 14px; }

  /* botones extra */
  .btn--ghost, .btn--ghost-dark {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 26px;
    border-radius: 100px;
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 1rem;
    text-decoration: none;
    transition: transform 0.15s, background 0.2s, box-shadow 0.2s;
  }
  .btn--ghost {
    background: #fff;
    color: #1f1a17;
    border: 2.5px solid #1f1a17;
    box-shadow: 4px 4px 0 #1f1a17;
  }
  .btn--ghost:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 #1f1a17; }
  .btn--ghost-dark {
    background: transparent;
    color: #fff;
    border: 2.5px solid rgba(255, 255, 255, 0.7);
  }
  .btn--ghost-dark:hover { background: rgba(255, 255, 255, 0.14); border-color: #fff; }

  /* ═══ 2 · BANNER PRECIO ════════════════════════════════════════════ */
  .precio-banner {
    background: var(--color-primary);
    color: #fff;
    border-top: 4px solid #1f1a17;
    border-bottom: 4px solid #1f1a17;
  }
  .precio-banner__inner {
    display: flex;
    align-items: center;
    gap: 22px;
    padding: 26px 0;
  }
  .precio-tag {
    font-size: 2.6rem;
    line-height: 1;
    flex-shrink: 0;
    filter: drop-shadow(2px 3px 0 rgba(31, 26, 23, 0.35));
  }
  .precio-claim {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 3.4vw, 2.2rem);
    line-height: 1.05;
    color: #fff;
    text-shadow: 2px 2px 0 #1f1a17;
  }
  .precio-sub {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: clamp(0.92rem, 1.8vw, 1.05rem);
    color: #fff4f5;
    margin-top: 4px;
  }

  /* ═══ 3 · INTRO ════════════════════════════════════════════════════ */
  .fest-intro { background: var(--color-light); }
  .fest-intro__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .fest-intro__text { display: flex; flex-direction: column; gap: 16px; }
  .fest-intro__text .btn { align-self: flex-start; margin-top: 8px; }
  .prose-p { color: #4a4540; line-height: 1.72; font-size: 1rem; }

  .fest-intro__media { position: relative; }
  .fest-intro__media img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    border-radius: 24px;
    border: 4px solid #1f1a17;
    box-shadow: 10px 10px 0 var(--color-primary);
  }
  .fest-intro__wm {
    position: absolute;
    top: -56px; right: -18px;
    z-index: 2;
  }

  /* ═══ 4 · CARTEL ═══════════════════════════════════════════════════ */
  .cartel {
    background: #1f1a17;
    padding: 26px 0 30px;
    border-top: 4px solid var(--color-primary);
    border-bottom: 4px solid #3FA7E0;
  }
  .cartel__head { margin-bottom: 14px; }
  .cartel__kicker {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #ffd0d7;
  }
  .cartel__ticker { overflow: hidden; width: 100%; }
  .cartel__track {
    display: flex;
    width: max-content;
    animation: cartel-scroll 38s linear infinite;
  }
  .cartel__track:hover { animation-play-state: paused; }
  .cartel__track span {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 4vw, 2.6rem);
    text-transform: uppercase;
    color: #fdfaf4;
    white-space: nowrap;
    padding: 0 1.4rem;
  }
  @keyframes cartel-scroll { to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) {
    .cartel__track { animation: none; }
  }

  /* ═══ 5 · OFERTA ═══════════════════════════════════════════════════ */
  .fest-oferta {
    position: relative;
    background:
      radial-gradient(circle at 12% 18%, rgba(63, 167, 224, 0.16) 0, transparent 32%),
      radial-gradient(circle at 88% 82%, rgba(232, 69, 90, 0.18) 0, transparent 34%),
      #15110e;
    color: #fff;
  }
  .oferta-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .oferta-card {
    background: rgba(255, 255, 255, 0.05);
    border: 2px solid rgba(255, 255, 255, 0.12);
    border-radius: 20px;
    padding: 28px 24px;
    transition: transform 0.18s, border-color 0.2s, background 0.2s;
  }
  .oferta-card:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--color-primary);
  }
  .oferta-emoji { display: block; font-size: 2.3rem; margin-bottom: 14px; line-height: 1; }
  .oferta-card h3 {
    font-family: var(--font-subheading);
    font-size: 1.12rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }
  .oferta-card p { font-size: 0.93rem; line-height: 1.6; color: rgba(255, 255, 255, 0.74); }

  /* ═══ 6 · POR QUÉ ══════════════════════════════════════════════════ */
  .fest-why { background: #fff; }
  .why-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .why-card {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    background: var(--color-light);
    border-radius: 18px;
    padding: 24px 22px;
    border: 2px solid rgba(31, 26, 23, 0.08);
    transition: transform 0.18s, box-shadow 0.2s;
  }
  .why-card:hover { transform: translateY(-3px); box-shadow: 6px 6px 0 rgba(232, 69, 90, 0.18); }
  .why-emoji { font-size: 1.9rem; flex-shrink: 0; margin-top: 2px; }
  .why-text strong {
    display: block;
    font-family: var(--font-subheading);
    font-weight: 700;
    font-size: 1.06rem;
    color: var(--color-dark);
    margin-bottom: 6px;
  }
  .why-text p { font-size: 0.94rem; color: #555; line-height: 1.6; }

  /* ═══ 7 · GALERÍA ══════════════════════════════════════════════════ */
  .fest-gallery { background: var(--color-light); }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .gallery-fig {
    margin: 0;
    border-radius: 18px;
    overflow: hidden;
    border: 3px solid #1f1a17;
    box-shadow: 6px 6px 0 var(--color-primary);
    aspect-ratio: 4 / 3;
  }
  .gallery-fig img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform 0.35s ease;
  }
  .gallery-fig:hover img { transform: scale(1.06); }

  /* ═══ 8 · CTA FINAL ════════════════════════════════════════════════ */
  .fest-cta {
    position: relative;
    overflow: hidden;
    padding: 100px 0 110px;
    text-align: center;
    color: #14202b;
  }
  .fest-cta--manchego {
    background: linear-gradient(180deg, #2f8fd4 0%, #62b6e8 55%, #9bd8f5 100%);
  }
  .fest-cta__scene { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .fest-cta__skyline { position: absolute; left: 0; right: 0; bottom: 0; height: 180px; }
  .fest-cta__skyline .wm { position: absolute; bottom: -8px; }
  .wm--cta-left { left: 7%; }
  .wm--cta-right { right: 7%; }

  .fest-cta__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .fest-cta__pre {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #15303f;
  }
  .fest-cta__h2 {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5.5vw, 3.6rem);
    color: #fff;
    margin-bottom: 2px;
    text-shadow: 4px 4px 0 #1f1a17;
  }
  .fest-cta__addr {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.02rem;
    color: #15303f;
    margin-bottom: 18px;
  }
  .fest-cta__btns { display: flex; flex-wrap: wrap; justify-content: center; gap: 14px; }

  /* ═══ RESPONSIVE (básico) ══════════════════════════════════════════ */
  @media (max-width: 820px) {
    .fest-intro__grid { grid-template-columns: 1fr; gap: 32px; }
    .oferta-grid { grid-template-columns: repeat(2, 1fr); }
    .why-grid { grid-template-columns: 1fr; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .fhero { padding: 130px 0 200px; }
    .wm--far, .wm--back { display: none; }
  }
  @media (max-width: 520px) {
    .oferta-grid { grid-template-columns: 1fr; }
    .precio-banner__inner { gap: 14px; }
  }
</style>
