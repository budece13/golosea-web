---
import Layout from "../layouts/Layout.astro";
import { content, images } from "../data/golosea";
---

<Layout
  title="Sobre Golosea | Tienda de chuches en El Bonillo"
  description="Conoce Golosea: tienda de golosinas y chucherías en El Bonillo (Albacete), cucuruchos personalizados y mucho más."
>
  <!-- Cabecera de página -->
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">Sobre Golosea</p>
      <h1>{content.about_title}</h1>
    </div>
  </section>

  <!-- NOSOTROS -->
  <section class="section about-section">
    <div class="container">
      <div class="about-grid">
        <img src={images.about.url} alt={images.about.alt} loading="lazy" />
        <div class="about-text">
          <p>{content.about_text}</p>
          <div class="why-grid">
            {content.why_choose.map((w) => (
              <div class="why-item">
                <div class="why-emoji">{w.emoji}</div>
                <div>
                  <h4>{w.title}</h4>
                  <p>{w.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="section">
    <div class="container">
      <div class="section-title">
        <h2>Nuestros <span>servicios</span></h2>
      </div>
      <div class="grid">
        {content.services.map((s) => (
          <article class="card">
            <div class="card-emoji">{s.emoji}</div>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- BLOG (placeholder) -->
  <section class="section blog-section">
    <div class="container">
      <div class="section-title">
        <h2>Del <span>blog</span></h2>
      </div>
      <div class="grid">
        {[1, 2, 3].map((n) => (
          <article class="card blog-card">
            <span class="blog-tag">Próximamente</span>
            <h3>Entrada del blog {n}</h3>
            <p>Aquí publicaremos recetas, curiosidades dulces y novedades de la tienda.</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-head {
    background: var(--color-light);
    padding: 120px 0 40px;
    text-align: center;
  }
  .page-head .eyebrow {
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-primary);
    margin-bottom: 8px;
  }
  .page-head h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-dark);
  }

  .about-section { background: var(--color-light); }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .about-grid img {
    border-radius: 18px;
    height: 100%;
    object-fit: cover;
    max-height: 420px;
    width: 100%;
  }
  .about-text > p {
    color: #444;
    margin-bottom: 28px;
    font-size: 1.025rem;
    line-height: 1.7;
  }

  .why-grid { display: flex; flex-direction: column; gap: 20px; }
  .why-item { display: flex; gap: 16px; align-items: flex-start; }
  .why-emoji { font-size: 1.6rem; flex-shrink: 0; }
  .why-item h4 { margin-bottom: 4px; font-size: 1rem; color: var(--color-dark); }
  .why-item p { color: #555; font-size: 0.9rem; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 24px;
  }
  .card {
    background: var(--color-light);
    border-radius: 16px;
    padding: 28px;
    border: 1px solid #eee;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .card:hover {
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
    transform: translateY(-4px);
  }
  .card-emoji { font-size: 2rem; margin-bottom: 12px; }
  .card h3 { margin-bottom: 8px; font-size: 1.15rem; color: var(--color-dark); }
  .card p { color: #555; font-size: 0.95rem; line-height: 1.5; }

  .blog-section { background: var(--color-light); }
  .blog-card { background: #fff; }
  .blog-tag {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 10px;
    border-radius: 999px;
    margin-bottom: 12px;
  }

  @media (max-width: 760px) {
    .about-grid { grid-template-columns: 1fr; }
  }
</style>
